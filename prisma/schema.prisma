// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Tenancy
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Clinic {
  id                         String    @id @default(cuid())
  slug                       String    @unique
  nameRu                     String
  nameUz                     String
  addressRu                  String?
  addressUz                  String?
  phone                      String?
  email                      String?
  logoUrl                    String?
  brandColor                 String    @default("#3DD5C0")
  timezone                   String    @default("Asia/Tashkent")
  currency                   Currency  @default(UZS)
  secondaryCurrency          Currency?
  exchangeRateToUsd          Decimal?  @db.Decimal(12, 4)
  workdayStart               String    @default("09:00")
  workdayEnd                 String    @default("19:00")
  slotMin                    Int       @default(30)
  tgBotUsername              String?
  tgBotToken                 String?
  tgWebhookSecret            String?
  kioskPin                   String?
  active                     Boolean   @default(true)
  // Phase 16 Wave 2 вҖ” NPS alert threshold. When a PatientReview lands with
  // `score < npsAlertThreshold`, the NPS submit path emits a LOW_NPS_RECEIVED
  // Action (severity high) and stamps `adminAlerted=true` on the review.
  // Default 7 matches the "promoter / passive / detractor" cutoff. Wave 3
  // exposes this in /crm/settings/clinic.
  npsAlertThreshold          Int       @default(7)
  // Phase 16 Wave 3 вҖ” Refer-a-friend reward percentage applied to the
  // referrer's NEXT booking after the referred patient completes their
  // first appointment. 0..50; 0 disables the reward. The Mini App refer
  // page shows this number; the auto-apply logic in booking POST reads it.
  referralRewardPercent      Int       @default(15)
  // Phase 16 Wave 3 вҖ” Master switch for medication reminders. When false,
  // the medication-reminder worker skips this clinic entirely. Doctors can
  // still author Prescription rows; their `remindersEnabled` flag is
  // independent so we don't lose existing setup if the master toggle is
  // flipped temporarily.
  medicationRemindersEnabled Boolean   @default(true)
  // РӨ6 (TZ-smart-constructor) вҖ” clinic mapping of prescription time-of-day
  // slots to clock times for reminders, e.g. {"MORNING":"08:00","NOON":"13:00",
  // "EVENING":"19:00","NIGHT":"22:00"}. Null = built-in defaults.
  medicationSlotTimes        Json?
  // Phase 17 Wave 2 вҖ” when true, every staff role in the clinic must enrol
  // TOTP, not just ADMIN/SUPER_ADMIN. Plan-gated: only Pro / Enterprise
  // plans can flip this on (Basic UI shows it disabled with an upsell hint).
  // Enforcement lives in the proxy/redirect guard.
  require2faForAll           Boolean   @default(false)
  // Phase 17 Wave 2 вҖ” clinic-level idle timeout in minutes. The proxy
  // invalidates a session whose lastActivityAt is older than this. App-level
  // bound is [5, 240]; the schema cannot express that, so the API + form
  // clamp on every write.
  sessionIdleTimeoutMinutes  Int       @default(30)
  // Monotonic counter for human-readable patient numbers. Incremented
  // atomically (UPDATE вҖҰ RETURNING) by allocatePatientNumber() in every
  // Patient creation path so each clinic gets its own 1, 2, 3 вҖҰ sequence.
  patientCounter             Int       @default(0)
  // Phase 19 Wave 1 вҖ” SaaS self-service.
  // `customSubdomain` lets Pro/Enterprise tenants serve the patient surfaces
  // off `<sub>.neurofax.uz` instead of the default `/c/<slug>`. Globally
  // unique because it routes traffic; nullable because Basic plans don't
  // get one. Wave 2 wires the resolver / DNS playbook.
  customSubdomain            String?   @unique
  // Phase 19 Wave 1 вҖ” second brand color for headers / accents on the
  // patient-facing surfaces. White-label feature gate decides whether the
  // UI exposes this; the column is always available so we don't need a
  // second migration when a clinic upgrades.
  brandSecondaryColor        String?
  // Phase 19 Wave 1 вҖ” onboarding milestones. `onboardedAt` flips the moment
  // the self-service wizard finishes (Wave 2). `onboardingPlaybook` records
  // which playbook variant the clinic picked (e.g. "dental", "general",
  // "aesthetic") so the seeded demo content + tour highlights match.
  // Free-form string (not enum) because the playbook catalog evolves
  // outside of schema migrations.
  onboardedAt                DateTime?
  onboardingPlaybook         String?
  // Smart-constructor РӨ0 вҖ” printed-document branding. `letterheadUrl` is a
  // full-width header image for printed conclusions/handouts (fallback: the
  // text header built from name/address/logo). `documentNumberPrefix` seeds
  // human-readable document numbers ("NF-2026-000123"); null derives the
  // prefix from the clinic slug.
  letterheadUrl              String?
  documentNumberPrefix       String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  users                    User[]
  doctors                  Doctor[]
  patients                 Patient[]
  appointments             Appointment[]
  cabinets                 Cabinet[]
  services                 Service[]
  payments                 Payment[]
  documents                Document[]
  documentCounters         DocumentCounter[]
  communications           Communication[]
  conversations            Conversation[]
  messages                 Message[]
  notificationTemplates    NotificationTemplate[]
  notificationSends        NotificationSend[]
  campaigns                Campaign[]
  cannedResponses          CannedResponse[]
  calls                    Call[]
  onlineRequests           OnlineRequest[]
  reviews                  Review[]
  exchangeRates            ExchangeRate[]
  providerConnections      ProviderConnection[]
  leads                    Lead[]
  auditLogs                AuditLog[]
  doctorSchedules          DoctorSchedule[]
  doctorTimeOffs           DoctorTimeOff[]
  appointmentServices      AppointmentService[]
  branches                 Branch[]
  subscription             Subscription?
  medicalCases             MedicalCase[]
  actions                  Action[]
  emptySlotSnapshots       EmptySlotSnapshot[]
  llmUsages                LLMUsage[]
  patientReviews           PatientReview[]
  patientFamilies          PatientFamily[]
  prescriptions            Prescription[]
  referralCodes            ReferralCode[]
  referralRewards          ReferralReward[]
  medicationReminderSends  MedicationReminderSend[]
  patientViews             PatientView[]
  userSessions             UserSession[]
  dataExportJobs           DataExportJob[]
  dataDeletionJobs         DataDeletionJob[]
  savedReports             SavedReport[]
  scheduledReports         ScheduledReport[]
  invoices                 Invoice[]
  patientAllergies         PatientAllergy[]
  patientChronicConditions PatientChronicCondition[]
  patientDiagnoses         PatientDiagnosis[]
  telegramInviteTokens     TelegramInviteToken[]
  visitNotes               VisitNote[]
  reminders                Reminder[]
  labResults               LabResult[]
  labOrders                LabOrder[]
  doctorPresets            DoctorPreset[]
  catalogOverlays          ClinicCatalogOverlay[]
  ePrescriptions           EPrescription[]
  sickLeaves               SickLeave[]
  cdsOverrides             CdsOverride[]
  referrals                Referral[]
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Branches (Phase 9a)
//
// A clinic may operate from multiple physical sites. The default per-clinic
// branch is created by migration backfill (slug='hq', isDefault=true) and the
// seed script attaches all generated demo content to it. Application code
// continues to query clinic-wide unless `runWithTenant` carries an explicit
// `branchId` вҖ” see `src/lib/tenant-context.ts` and `src/lib/prisma.ts`.
//
// Branch-scoped models keep `branchId` NULLABLE in this migration so prod
// rollouts can backfill at their own pace. Phase 9b tightens to NOT NULL
// after every existing row is reconciled.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  slug      String
  nameRu    String
  nameUz    String
  address   String?
  phone     String?
  timezone  String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors            Doctor[]
  cabinets           Cabinet[]
  appointments       Appointment[]
  doctorSchedules    DoctorSchedule[]
  doctorTimeOffs     DoctorTimeOff[]
  actions            Action[]
  emptySlotSnapshots EmptySlotSnapshot[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  date      DateTime
  rateUsd   Decimal  @db.Decimal(12, 4)
  source    String?
  createdAt DateTime @default(now())

  @@unique([clinicId, date])
  @@index([clinicId, date])
}

// Encrypted per-tenant provider credentials (tg, sms, payme, etc).
model ProviderConnection {
  id           String       @id @default(cuid())
  clinicId     String
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  kind         ProviderKind
  label        String?
  // Encrypted payload (JSON) вҖ” cipher-text only; decryption is app-side.
  secretCipher String
  config       Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([clinicId, kind, label])
  @@index([clinicId, kind])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Plans + Subscriptions (Phase 9b)
//
// `Plan` is a small catalog of SaaS tiers (basic / pro / enterprise). Feature
// gates live in `features` (Json) so we can extend them without touching the
// schema. `Subscription` ties exactly one plan to one clinic вҖ” there is at
// most one active row per clinic (`@unique` on clinicId).
//
// The migration that introduces these tables also seeds the canonical three
// plans and gives every existing clinic a TRIAL on `pro` so prod rollouts
// don't leave anyone behind. Phase 9c builds the admin UI; Phase 9d wires
// feature flags into navigation.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Plan {
  id         String   @id @default(cuid())
  slug       String   @unique
  nameRu     String
  nameUz     String
  priceMonth Decimal  @db.Decimal(12, 2)
  currency   Currency @default(UZS)
  // {hasTelegramInbox, hasCallCenter, hasAnalyticsPro, maxBranches, maxUsers}
  features   Json
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                  String             @id @default(cuid())
  clinicId            String             @unique
  clinic              Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  // Phase 19 Wave 3 вҖ” set when an upgrade is initiated (DRAFT Invoice
  // minted). On the corresponding `INVOICE_PAID` transition we move the
  // value into `planId` and clear this column. Allows the billing UI to
  // show "Upgrade to Pro pending payment" without yet entitling the
  // tenant to the higher tier's feature flags.
  pendingPlanId       String?
  status              SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([currentPeriodEndsAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Invoices (Phase 19 Wave 1)
//
// One Invoice row per billing period per clinic. The MVP path:
//   - Wave 2 admin self-service downgrade flow stamps DRAFT/ISSUED rows.
//   - Click/Payme webhooks (Wave 4) flip ISSUED вҶ’ PAID and populate
//     `paymentRef`. The unpaid sweeper flips ISSUED вҶ’ OVERDUE after `dueAt`.
//
// `amountTiins` is BigInt because invoice totals span months/years and can
// overflow the Int range used by the per-row Payment model. `number` is the
// human-readable identifier shown to the customer and on the PDF.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

model Invoice {
  id          String        @id @default(cuid())
  clinicId    String
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  number      String        @unique
  status      InvoiceStatus @default(DRAFT)
  amountTiins BigInt
  currency    Currency      @default(UZS)
  periodStart DateTime
  periodEnd   DateTime
  dueAt       DateTime
  paidAt      DateTime?
  paymentRef  String?
  pdfUrl      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clinicId, createdAt])
  @@index([status])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Self-service signup tokens (Phase 19 Wave 2)
//
// One row per `/signup` form submission. The token is a url-safe random ID
// the visitor receives by email; clicking the confirm link consumes the row,
// provisions Clinic + ADMIN + TRIAL Subscription, and applies the chosen
// onboarding playbook.
//
// Intentionally NOT joined back to Clinic вҖ” the row outlives the clinic for
// audit purposes (a future GC sweeps consumed/expired rows independently).
// `consumedClinicId` is denormalized so we can correlate without an FK.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model ClinicSignupToken {
  id               String    @id @default(cuid())
  email            String
  clinicName       String
  phone            String?
  planSlug         String    @default("basic")
  // null = "start blank" path. Otherwise one of the 5 catalog slugs
  // (general / dental / neurology / pediatric / cosmetology) вҖ” kept as a
  // free-form string so the catalog can evolve without a migration.
  playbookSlug     String?
  preferredLocale  String    @default("ru") // "ru" | "uz"
  token            String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedClinicId String?

  @@index([email])
  @@index([expiresAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// SUPER_ADMIN impersonation grants (Phase 19 Wave 4)
//
// Today the `admin_clinic_override` cookie is the only mechanism. Wave 4 pairs
// each switch-into-clinic action with a row here so we can:
//   - require a free-text reason (forensic / support audit trail)
//   - time-bound the grant (default 60min lease) and auto-expire
//   - flip into `VIEW_ONLY` mode where the API wrapper rejects writes
//   - emit STARTED / ENDED / EXPIRED audit transitions
//
// No FK back to User or Clinic on purpose: the row must outlive a deleted
// clinic so support / compliance can still see who did what when reviewing
// historical incidents (mirrors `ClinicSignupToken`).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ImpersonationMode {
  WRITE
  VIEW_ONLY
}

model ImpersonationGrant {
  id           String            @id @default(cuid())
  superAdminId String
  clinicId     String
  reason       String
  mode         ImpersonationMode @default(WRITE)
  startedAt    DateTime          @default(now())
  expiresAt    DateTime
  endedAt      DateTime?
  // "user_exit" | "expired" | "revoked"
  endedReason  String?

  @@index([superAdminId, startedAt])
  @@index([expiresAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Auth (NextAuth) + Staff
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model User {
  id                 String    @id @default(cuid())
  // SUPER_ADMIN has clinicId = null; every other user is bound to a single clinic.
  clinicId           String?
  clinic             Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  email              String
  emailVerified      DateTime?
  passwordHash       String?
  name               String
  photoUrl           String?
  phone              String?
  telegramId         String?
  role               Role      @default(DOCTOR)
  active             Boolean   @default(true)
  // Set true when an admin issues a temp password; cleared on first self-set.
  // Middleware redirects users with this flag to /crm/me/change-password.
  mustChangePassword Boolean   @default(false)
  // The user (SUPER_ADMIN or ADMIN) who created/invited this account.
  // No back-relation needed вҖ” surfaced only in audit views.
  invitedById        String?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Phase 17 Wave 2 reservations вҖ” added in Wave 1 to avoid a second
  // migration when 2FA + session-rotation lands. Wave 2 will populate
  // `totpSecret` (encrypted) + `recoveryCodesHash` (bcrypt of one-time
  // codes; NEVER plaintext) and start stamping `lastSessionRotatedAt`
  // from session middleware.
  totpSecret           String?
  totpEnabledAt        DateTime?
  recoveryCodesHash    String[]
  lastSessionRotatedAt DateTime?
  // Phase 17 Wave 2 hardening вҖ” server-side pinning of an in-flight TOTP
  // enrolment. /enroll writes (pendingTotpSecret, pendingTotpExpiresAt);
  // /verify must match against this row instead of trusting the client to
  // echo back the secret. TTL is short (10 min) and the fields are wiped on
  // successful verify or by the next /enroll call.
  pendingTotpSecret    String?
  pendingTotpExpiresAt DateTime?

  // Staff UI language preference (mirrors ClinicSignupToken.preferredLocale).
  // Persisted server-side via PATCH /api/me so the choice survives across
  // devices/browsers; seeds the NEXT_LOCALE cookie at sign-in so a fresh
  // browser lands in the saved language. Single source of truth a future
  // staff-notification dispatcher reads to localise its sends.
  preferredLocale      String    @default("ru") // "ru" | "uz"

  doctor                      Doctor?
  accounts                    Account[]
  sessions                    Session[]
  auditLogs                   AuditLog[]
  patientViews                PatientView[]
  userSessions                UserSession[]
  assignedConvs               Conversation[]          @relation("ConversationAssignee")
  calls                       Call[]                  @relation("CallOperator")
  sentMessages                Message[]               @relation("MessageSender")
  uploadedDocuments           Document[]              @relation("DocumentUploader")
  createdAppointments         Appointment[]           @relation("AppointmentCreator")
  confirmedAppointments       Appointment[]           @relation("AppointmentConfirmer")
  createdCampaigns            Campaign[]              @relation("CampaignCreator")
  savedReports                SavedReport[]           @relation("SavedReportCreator")
  createdTelegramInviteTokens TelegramInviteToken[]   @relation("TelegramInviteTokenCreator")
  // Phase 20 Wave 5a вҖ” doctor surface productivity tables. The `doctorId`
  // on Reminder + LabResult points at the User row (not Doctor) because the
  // permission gate is "is this the assigned user?" and the userвҶ’doctor
  // mapping is 1:1 anyway.
  reminders                   Reminder[]              @relation("DoctorReminders")
  labResults                  LabResult[]             @relation("DoctorLabResults")
  labOrders                   LabOrder[]              @relation("DoctorLabOrders")
  notificationPref            DoctorNotificationPref?
  catalogFavorites            DoctorFavorite[]
  ePrescriptions              EPrescription[]         @relation("DoctorEPrescriptions")
  sickLeaves                  SickLeave[]             @relation("DoctorSickLeaves")
  cdsOverrides                CdsOverride[]           @relation("DoctorCdsOverrides")
  referralsFrom               Referral[]              @relation("ReferralFromDoctor")
  referralsTo                 Referral[]              @relation("ReferralToDoctor")

  // Global uniqueness of email across the whole installation + per-clinic lookup.
  @@unique([email])
  @@index([clinicId, role])
  @@index([clinicId, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Doctor {
  id               String   @id @default(cuid())
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  slug             String
  nameRu           String
  nameUz           String
  specializationRu String
  specializationUz String
  photoUrl         String?
  bioRu            String?  @db.Text
  bioUz            String?  @db.Text
  rating           Decimal? @db.Decimal(3, 2)
  reviewCount      Int      @default(0)
  color            String   @default("#3DD5C0")
  pricePerVisit    Int?
  salaryPercent    Int      @default(40)
  // Cap on pre-bookable slots/day. The booking grid steps every 20 min and
  // offers at most this many; the rest of the day is the live walk-in queue.
  // Doctors raise it in their own settings when they want more appointments.
  maxBookableSlotsPerDay Int @default(3)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // DoctorвҶ”Cabinet 1:1 binding. NOT NULL вҖ” every doctor must occupy a
  // cabinet (no headless doctors). UNIQUE вҖ” one doctor per cabinet, no
  // shared shifts. onDelete: Restrict prevents deleting a cabinet while
  // it's still occupied; admin must reassign first.
  cabinetId String  @unique
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Restrict)

  // Doctor's wet-signature image (MinIO public URL). Stamped into the PDF
  // print template at `/api/crm/visit-notes/[id]/print`. Optional вҖ” falls
  // back to a typed signature in the PDF when missing.
  signatureUrl String?

  services           ServiceOnDoctor[]
  schedules          DoctorSchedule[]
  timeOffs           DoctorTimeOff[]
  appointments       Appointment[]
  leads              Lead[]
  primaryCases       MedicalCase[]
  emptySlotSnapshots EmptySlotSnapshot[]
  patientReviews     PatientReview[]
  prescriptions      Prescription[]
  visitNotes         VisitNote[]
  presets            DoctorPreset[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
  @@index([clinicId, specializationRu])
  @@index([clinicId, branchId])
}

// Per-doctor reusable preset for a structured field on a VisitNote.
//
// One row = one chip that appears under a ChipFieldCard. Clicking it both
// pushes `fieldValue` into the structured array on the active VisitNote AND
// appends `noteTemplate` (if set) to bodyMarkdown вҖ” the "smart constructor"
// behavior. Doctors manage their own presets in /doctor/settings.
//
// `field` partitions the row by VisitNote field so the editor can render
// one chip-row per card without filtering on the client.
model DoctorPreset {
  id           String            @id @default(cuid())
  clinicId     String
  clinic       Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctorId     String
  doctor       Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  field        DoctorPresetField
  // Short label shown on the chip itself, e.g. "Р“РҫР»РҫРІРҪР°СҸ РұРҫР»СҢ".
  label        String
  // Value appended to the structured array on VisitNote (e.g. into
  // VisitNote.complaints). Usually equal to `label`, but kept separate so
  // the chip can display a short label while the stored value carries
  // qualifiers like "Р“РҫР»РҫРІРҪР°СҸ РұРҫР»СҢ, РҙР°РІСҸСүР°СҸ, > 1 РҪРөРҙ".
  fieldValue   String
  // Markdown snippet appended to VisitNote.bodyMarkdown when the chip is
  // clicked. Null/empty = chip only mutates the structured array.
  noteTemplate String?           @db.Text
  sortOrder    Int               @default(0)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([clinicId, doctorId, field, active, sortOrder])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Catalog
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

// Platform-wide drug catalog (РңРқРқ + brand mappings). NOT scoped to clinic вҖ”
// curated globally. Per-clinic overrides come later via a thin overlay table
// (Phase G6). Doctor presets in PRESCRIPTIONS can either be plain strings
// (legacy) or reference a drugId (new path вҖ” gives us the structured view).
model Drug {
  // Stable slug-style id so frontend code can hard-code references to common
  // drugs in protocols (e.g. "bisoprolol"). Migration backfill creates these
  // from the canonical `inn` lowercased.
  id                String            @id
  // INN (International Nonproprietary Name) in Latin вҖ” the canonical handle.
  // Unique because brand names overlap (e.g. "РҗСҒРҝРёСҖРёРҪ" is a brand for ASA).
  inn               String            @unique
  nameRu            String
  nameUz            String?
  // WHO Anatomical Therapeutic Chemical code вҖ” used for interaction lookup
  // (Phase G4) and grouping. Optional because not every herbal/supplement
  // has one.
  atcCode           String?
  category          DrugCategory
  // Forms + strengths shipped as JSON to keep the row count down and let
  // the dosage-builder UI evolve without migrations. Shape:
  //   [{ form: "TAB", strengths: ["2,5 РјРі", "5 РјРі"] }, ...]
  forms             Json
  // Common indications as ICD-10 prefixes ("I10", "G43") вҖ” drives the
  // diagnosis-driven suggestion engine in Phase G2.
  indications       String[]          @default([])
  // Plain-text bullet list (RU), one item per array slot. Rendered as
  // hover-tooltip in the prescription chip.
  contraindications String[]          @default([])
  sideEffects       String[]          @default([])
  pregnancyCat      PregnancyCategory @default(UNKNOWN)
  // Default dosing copy by patient subgroup. JSON for shape flexibility:
  //   { adult: "РҹРҫ 1 СӮР°Рұ 2 СҖР°Р·Р° РІ РҙРөРҪСҢ, РҙР»РёСӮРөР»СҢРҪРҫ", pediatric: "...", renal: "..." }
  defaultDosing     Json?
  // Rx-only = СӮСҖРөРұСғРөСӮ СҖРөСҶРөРҝСӮР°. Most drugs are rx; OTC includes vitamins,
  // some analgesics. Drives e-recipe formatting in Phase G7.
  rxOnly            Boolean           @default(true)
  // Hide from search without deleting (preserves historical references in
  // VisitNote.prescriptions[]).
  active            Boolean           @default(true)
  // РӨ4 вҖ” null for the curated global catalog; set when a clinic adds its own
  // drug. Cross-tenant by design (Drug is in MODELS_WITHOUT_TENANT); routes
  // filter `clinicId IN (null, ctx.clinicId)` manually, like DiagnosisGuide.
  clinicId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  brands             DrugBrand[]
  interactionsAsA    DrugInteraction[]   @relation("DrugA")
  interactionsAsB    DrugInteraction[]   @relation("DrugB")
  visitPrescriptions VisitPrescription[]

  @@index([category, active])
  @@index([atcCode])
  @@index([clinicId, active])
}

// Phase G4 вҖ” drug-drug interaction registry. Pairs of drugs that should not
// be co-prescribed (or require caution). The CDS engine walks current
// prescriptions on the visit note, builds the pair set, and emits warnings.
// Curated globally; per-clinic overrides ride in G6.
enum DrugInteractionSeverity {
  MINOR
  MODERATE
  MAJOR
  CONTRAINDICATED
}

model DrugInteraction {
  id            String                  @id @default(cuid())
  drugAId       String
  drugBId       String
  drugA         Drug                    @relation("DrugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugB         Drug                    @relation("DrugB", fields: [drugBId], references: [id], onDelete: Cascade)
  severity      DrugInteractionSeverity
  // Plain-text mechanism (RU), e.g. "РЈСҒРёР»РөРҪРёРө РіРёРҝРҫРіР»РёРәРөРјРёСҮРөСҒРәРҫРіРҫ СҚС„С„РөРәСӮР°".
  mechanism     String?                 @db.Text
  // One-line clinical advice (RU) shown in the warning chip.
  advice        String                  @db.Text
  // ICD-10 prefixes that elevate this interaction's risk (e.g. "I50" for
  // heart-failure raising the floor of NSAID risk). Empty for general pairs.
  riskDiagnoses String[]                @default([])
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([drugAId, drugBId])
  @@index([drugAId])
  @@index([drugBId])
}

// Brand name вҶ’ drug mapping. Search by brand (e.g. "РҡРҫРҪРәРҫСҖ") resolves
// to the underlying INN (bisoprolol) so doctors can type either.
model DrugBrand {
  id           String   @id @default(cuid())
  drugId       String
  drug         Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
  name         String
  manufacturer String?
  createdAt    DateTime @default(now())

  @@index([drugId])
  @@index([name])
}

// Phase G2 вҖ” clinical protocol bundles. A ClinicalProtocol packages a complete
// "standard of care" snapshot for a diagnosis: complaints/anamnesis/exam
// templates (chips for the structured fields), default prescriptions (drug
// ids), recommended labs (codes, wired into Phase G3), advice copy, and an
// optional conclusion-markdown block that appends to the editor. The doctor
// can apply one with a single click ("РҹСҖРёРјРөРҪРёСӮСҢ СҒСӮР°РҪРҙР°СҖСӮ") and then edit.
//
// Match is by `diagnosisCodePrefix` against the chosen ICD-10 code вҖ” "I10"
// matches all I10.* subcodes. Higher specificity wins (longer prefix first).
//
// РӨ3 (TZ-smart-constructor) вҖ” three ownership scopes via nullable columns
// (same cross-tenant pattern as DiagnosisGuide; listed in
// MODELS_WITHOUT_TENANT, routes scope manually):
//   clinicId null + doctorId null  вҶ’ curated global seed
//   clinicId set  + doctorId null  вҶ’ clinic-own (ADMIN manages)
//   clinicId set  + doctorId set   вҶ’ doctor-personal (В«СҒРҫС…СҖР°РҪРёСӮСҢ РәР°Рә РҝСҖРҫСӮРҫРәРҫР»В»)
// Apply priority: personal вҶ’ clinic вҶ’ global; within a scope longest
// prefix, then sortOrder.
model ClinicalProtocol {
  id                    String   @id @default(cuid())
  clinicId              String?
  doctorId              String?
  /**
   * ICD-10 prefix this protocol activates for, e.g. "I10", "E11", "K21".
   */
  diagnosisCodePrefix   String
  /**
   * RU heading shown in the apply-confirm modal.
   */
  nameRu                String
  nameUz                String?
  /**
   * One-liner shown under the heading.
   */
  summaryRu             String?
  /**
   * Chip values for the corresponding structured field.
   */
  complaintsTemplate    String[] @default([])
  anamnesisTemplate     String[] @default([])
  examinationTemplate   String[] @default([])
  /**
   * Legacy free-text lines (e.g. "Р‘РёСҒРҫРҝСҖРҫР»РҫР» 5 РјРі вҖ” РҝРҫ 1 СӮР°Рұ СғСӮСҖРҫРј").
   * Fallback only вҖ” used when `prescriptionItems` is empty (РӨ3).
   */
  prescriptionsTemplate String[] @default([])
  /**
   * РӨ3 вҖ” structured prescription drafts, the VisitPrescriptionDraft shape:
   * [{drugId?, displayName, form?, strength?, dose, timesOfDay[],
   *   mealRelation, durationDays?, instructionRu?, instructionUz?,
   *   remindPatient}]. Applying a protocol appends these as
   * VisitPrescription rows; В«СҒРҫС…СҖР°РҪРёСӮСҢ РәР°Рә РҝСҖРҫСӮРҫРәРҫР»В» writes them back.
   */
  prescriptionItems     Json?
  adviceTemplate        String[] @default([])
  /**
   * Lab order codes вҖ” populated in G3 when LabTest catalog lands.
   */
  recommendedLabs       String[] @default([])
  /**
   * Optional markdown block that appends to the conclusion editor.
   */
  conclusionTemplateMd  String?
  /**
   * РӨ3 вҖ” link to the DiagnosisGuide this protocol pairs with (guide.code).
   */
  guideCode             String?
  /**
   * РӨ3 вҖ” suggested follow-up interval surfaced on apply.
   */
  followUpDays          Int?
  /**
   * Sort hint when multiple protocols share a prefix.
   */
  sortOrder             Int      @default(0)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([diagnosisCodePrefix, active])
  @@index([clinicId, active])
  @@index([doctorId, active])
}

// Phase G5 вҖ” patient handout library. Curated Markdown snippets the doctor
// can drop into VisitNote.patientHandoutMarkdown. Matched against the active
// diagnosis via `matchPrefixes` (e.g. ["I10","I11"] for hypertension), plus
// topic-based browsing for generic snippets (food hygiene, AB rules, BP diary).
model HandoutTemplate {
  id            String   @id @default(cuid())
  // Stable slug ("HTN_LIFESTYLE", "AB_RULES") for code references.
  code          String   @unique
  titleRu       String
  titleUz       String?
  // 1-line subtitle shown under the title in the picker list.
  summaryRu     String?
  // Markdown body that appends to the handout draft.
  bodyMd        String   @db.Text
  // РӨ4 вҖ” Uzbek body. Null falls back to bodyMd (RU) at insert time; the
  // picker offers the UZ variant when present.
  bodyMdUz      String?  @db.Text
  // ICD-10 prefixes this handout applies to. Empty = general (always shown
  // under the "РһРұСүРөРө" tab).
  matchPrefixes String[] @default([])
  // RU category label for filter tabs ("РһРұСҖР°Р· Р¶РёР·РҪРё", "РҹСҖРёС‘Рј РҝСҖРөРҝР°СҖР°СӮРҫРІ", вҖҰ).
  topic         String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  // РӨ4 вҖ” null for the global library; set for clinic-own handouts. Same
  // cross-tenant convention as DiagnosisGuide / Drug.
  clinicId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
  @@index([clinicId, active])
}

// РӨ1 (TZ-smart-constructor) вҖ” diagnosis knowledge base. When the doctor sets
// an ICD-10 code, the longest-matching guide surfaces under the diagnosis
// with structured patient-facing blocks (what to do / care / lifestyle /
// red flags) in RU+UZ, ready-made advice chips and a default follow-up.
// Structured blocks (not one blob) so print composes per-section and the
// doctor can insert pieces selectively.
//
// `clinicId` is null for the curated global seed; a clinic can add its own
// guides (РӨ4). Cross-tenant reads by design вҶ’ listed in
// MODELS_WITHOUT_TENANT, routes filter `clinicId IN (null, ctx.clinicId)`
// manually. Prefix match follows the ClinicalProtocol convention: longest
// `matchPrefix` wins.
model DiagnosisGuide {
  id                  String   @id @default(cuid())
  clinicId            String?
  // Stable slug ("g43-migraine") вҖ” overlay + favorites key (CatalogEntityType.GUIDE).
  code                String
  // ICD-10 prefix, e.g. "G43" or "G43.0".
  matchPrefix         String
  titleRu             String
  titleUz             String?
  whatToDoRu          String?  @db.Text
  whatToDoUz          String?  @db.Text
  careRu              String?  @db.Text
  careUz              String?  @db.Text
  lifestyleRu         String?  @db.Text
  lifestyleUz         String?  @db.Text
  redFlagsRu          String?  @db.Text
  redFlagsUz          String?  @db.Text
  // Ready-made chips for the advice field ("РЎРҝР°СӮСҢ 7вҖ“8 СҮР°СҒРҫРІ", вҖҰ).
  adviceChips         String[] @default([])
  defaultFollowUpDays Int?
  sortOrder           Int      @default(0)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clinicId, code])
  @@index([matchPrefix, active])
}

// Phase G6 вҖ” Clinic overlay + doctor favorites.
//
// `ClinicCatalogOverlay` lets a clinic hide a global catalog entry (drug,
// protocol, handout, lab test/panel) so it disappears from search/order
// surfaces without mutating the curated source. Future iterations may
// extend this with a JSON `overrides` patch (custom local dosing notes,
// renamed handouts, вҖҰ) вҖ” the `overridesJson` column is reserved now to
// avoid a second migration.
//
// `DoctorFavorite` is the per-user "вҳ… pin" вҖ” favourites float to the top
// of catalog drawers so common picks stay one click away. Per-user (not
// per-clinic) because every doctor's preference shape is different.
//
// Both tables key entries by (entityType, entityCode) вҖ” `entityCode` is the
// stable slug (Drug.id is INN-derived; HandoutTemplate.code; LabTest.code;
// LabPanel.code; ClinicalProtocol.code).
enum CatalogEntityType {
  DRUG
  PROTOCOL
  HANDOUT
  LAB_TEST
  LAB_PANEL
  GUIDE
}

model ClinicCatalogOverlay {
  id            String            @id @default(cuid())
  clinicId      String
  clinic        Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  entityType    CatalogEntityType
  entityCode    String
  // When true, hide the global entry entirely for this clinic. MVP is
  // hide-only; future overrides land in `overridesJson`.
  hideGlobal    Boolean           @default(true)
  // Reserved for G8 вҖ” JSON patch applied on top of the curated row before
  // surfacing it in the doctor UI. Null until then.
  overridesJson Json?
  createdById   String
  updatedById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([clinicId, entityType, entityCode])
  @@index([clinicId, entityType])
}

model DoctorFavorite {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType CatalogEntityType
  entityCode String
  // Lower = pinned higher in the drawer list. Defaults to insertion order
  // by epoch ms; reorder UI can update this in batch later.
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())

  @@unique([userId, entityType, entityCode])
  @@index([userId, entityType, sortOrder])
}

// Phase G3 вҖ” Lab catalog + ordering.
//
// `LabTest` is the controlled vocabulary of individual analyses ("РһРҗРҡ",
// "Р“Р»СҺРәРҫР·Р°", "TSH") with reference ranges and turnaround. `LabPanel` groups
// commonly-ordered tests into named bundles (e.g. "Р‘РёРҫС…РёРјРёСҸ РұР°Р·РҫРІР°СҸ").
// `LabOrder` is the actual order the doctor creates from a visit: a snapshot
// of selected test codes + panels, with a printable РҪР°РҝСҖР°РІР»РөРҪРёРө and a QR
// linking to its detail page once the lab/result-entry UI lands.
enum Biomaterial {
  BLOOD
  SERUM
  PLASMA
  URINE
  STOOL
  SALIVA
  SWAB
  TISSUE
  CSF
  SPUTUM
  OTHER
}

enum LabOrderStatus {
  DRAFT
  ORDERED
  COLLECTED
  COMPLETED
  CANCELLED
}

enum LabUrgency {
  ROUTINE
  URGENT
  STAT
}

model LabTest {
  id              String      @id
  /**
   * Short clinical code shown in chips and on the print form, e.g. "CBC", "GLU".
   */
  code            String      @unique
  nameRu          String
  nameUz          String?
  /**
   * LOINC code reserved for future integrations.
   */
  loinc           String?
  biomaterial     Biomaterial
  /**
   * Free-text unit ("Рі/Р»", "РјРәРјРҫР»СҢ/Р»", "СӮСӢСҒ/РјРәР»"). Optional for qualitative tests.
   */
  unit            String?
  /**
   * Reference ranges as JSON array. Each entry:
   * { sex?: "M" | "F", ageMinMo?: number, ageMaxMo?: number, low?: number, high?: number, text?: string }
   * Server-side helpers (G3+) resolve the matching row per patient.
   */
  refRanges       Json?
  /**
   * Approximate turnaround in hours; UI shows "вүҲ XСҮ".
   */
  turnaroundHours Int         @default(24)
  /**
   * Per-test price in UZS; optional, used by future billing wiring.
   */
  priceUzs        Int?
  /**
   * ICD-10 prefixes this test is commonly ordered for вҖ” drives "recommended" badges.
   */
  commonForCodes  String[]    @default([])
  /**
   * Free-text preparation hint for the patient ("РҪР°СӮРҫСүР°Рә", "РҙРҫ 10:00").
   */
  patientPrep     String?
  active          Boolean     @default(true)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  panels LabPanelTest[]

  @@index([active, sortOrder])
}

model LabPanel {
  id          String   @id @default(cuid())
  code        String   @unique
  nameRu      String
  nameUz      String?
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tests LabPanelTest[]

  @@index([active, sortOrder])
}

/**
 * Join table вҖ” keeps the test catalog and panels in their own rows so a
 * test can belong to multiple panels and we can attach optional metadata
 * (sort order within the panel) later without touching either side.
 */
model LabPanelTest {
  panelId   String
  panel     LabPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  testId    String
  test      LabTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)

  @@id([panelId, testId])
  @@index([testId])
}

model LabOrder {
  id            String       @id @default(cuid())
  /**
   * Short, human-readable order number stamped at create (e.g. "LO-20260518-0042").
   */
  orderNumber   String       @unique
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User         @relation("DoctorLabOrders", fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  visitNoteId   String?
  visitNote     VisitNote?   @relation(fields: [visitNoteId], references: [id])

  /**
   * Snapshot of test codes at order time вҖ” survives catalog edits.
   */
  testCodes     String[]       @default([])
  /**
   * Snapshot of panel codes at order time.
   */
  panelCodes    String[]       @default([])
  /**
   * Optional ICD-10 code copied from the visit note for the lab's reference.
   */
  diagnosisCode String?
  notes         String?        @db.Text
  urgency       LabUrgency     @default(ROUTINE)
  status        LabOrderStatus @default(ORDERED)
  /**
   * Stamped when the doctor opens the print preview.
   */
  printedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, doctorId, createdAt])
  @@index([clinicId, status, createdAt])
}

enum EPrescriptionStatus {
  ISSUED
  CANCELLED
}

enum SickLeaveRegimen {
  OUTPATIENT
  HOSPITAL
  HOME
}

enum SickLeaveStatus {
  ISSUED
  CANCELLED
}

model EPrescription {
  id            String              @id @default(cuid())
  // Human-readable receipt number, e.g. "RX-20260518-0042".
  rxNumber      String              @unique
  // Public verification token printed as a QR вҖ” opaque, unguessable.
  verifyToken   String              @unique
  clinicId      String
  clinic        Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient             @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User                @relation("DoctorEPrescriptions", fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id])
  visitNoteId   String?
  visitNote     VisitNote?          @relation(fields: [visitNoteId], references: [id])
  // Snapshot ICD-10 from the visit at issue time so cancellations still print.
  diagnosisCode String?
  diagnosisName String?
  // Snapshot of doctor's signature image URL at issue time. Empty if doctor
  // had no signature on file вҖ” the print falls back to the typed name.
  signatureUrl  String?
  // Items: [{ drugId, drugName, dose, route, frequency, durationDays, instructions, notes }]
  items         Json                @default("[]")
  notes         String?             @db.Text
  issuedAt      DateTime            @default(now())
  // Default validUntil = issuedAt + 30d; computed and stored at create.
  validUntilAt  DateTime
  printedAt     DateTime?
  status        EPrescriptionStatus @default(ISSUED)
  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, doctorId, createdAt])
  @@index([clinicId, status, createdAt])
}

model SickLeave {
  id            String           @id @default(cuid())
  // Human-readable certificate number, e.g. "SL-20260518-0042".
  certNumber    String           @unique
  // Public verification token printed as a QR вҖ” opaque, unguessable.
  verifyToken   String           @unique
  clinicId      String
  clinic        Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient          @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User             @relation("DoctorSickLeaves", fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id])
  visitNoteId   String?
  visitNote     VisitNote?       @relation(fields: [visitNoteId], references: [id])
  diagnosisCode String?
  diagnosisName String?
  signatureUrl  String?
  regimen       SickLeaveRegimen @default(OUTPATIENT)
  periodFrom    DateTime         @db.Date
  periodTo      DateTime         @db.Date
  // Free-form restrictions (e.g. "no heavy lifting", "indoor work only").
  restrictions  String?          @db.Text
  notes         String?          @db.Text
  issuedAt      DateTime         @default(now())
  printedAt     DateTime?
  status        SickLeaveStatus  @default(ISSUED)
  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, doctorId, createdAt])
  @@index([clinicId, status, periodFrom])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// G8 вҖ” CDS override audit. One row per CDS warning that the doctor chose
// to override (i.e., kept the prescription despite a flagged interaction,
// allergy, duplicate-class, pregnancy, or diagnosis-risk warning). Recording
// is mandatory before a visit can be finalized with unresolved warnings,
// which gives the quality team an audit trail and lets the analytics
// dashboard surface override-heavy doctors or recurring patterns.
//
// Snapshot fields (warningTitle, warningDetail, severity) are required вҖ”
// the CDS rules table can evolve without breaking historical override
// records. The two pointers (visitNoteId, appointmentId) are nullable so
// the same shape can later cover overrides taken outside of an active
// reception (e.g. retrospective audit annotations).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum CdsOverrideReason {
  CLINICALLY_JUSTIFIED
  PATIENT_INFORMED
  ALTERNATIVES_TRIED
  FALSE_POSITIVE
  OTHER
}

model CdsOverride {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        User         @relation("DoctorCdsOverrides", fields: [doctorId], references: [id])
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  visitNoteId   String?
  visitNote     VisitNote?   @relation(fields: [visitNoteId], references: [id])

  // Snapshot of the warning at override time. `warningKind` matches the
  // CDS engine's discriminator (ALLERGY|INTERACTION|DUPLICATE_CLASS|
  // PREGNANCY|DIAGNOSIS_RISK); `severity` mirrors CdsSeverity.
  warningKind   String
  severity      String
  warningTitle  String
  warningDetail String  @db.Text
  // Free-form stable key emitted by the CDS engine вҖ” useful for collapsing
  // duplicate overrides across reprints of the same warning.
  warningKey    String?

  reason     CdsOverrideReason
  reasonNote String?           @db.Text

  createdAt DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([clinicId, doctorId, createdAt])
  @@index([clinicId, patientId, createdAt])
  @@index([visitNoteId])
}

model Service {
  id             String   @id @default(cuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  code           String
  nameRu         String
  nameUz         String
  category       String?
  durationMin    Int      @default(30)
  priceBase      Int
  // Free-repeat policy: when set, the N-th appointment in the same MedicalCase
  // within `freeRepeatDays` of the case's first appointment is priced at 0.
  // null = no free-repeat policy. Doctor-level overrides may be added later.
  freeRepeatDays Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctors             ServiceOnDoctor[]
  appointmentServices AppointmentService[]
  primaryAppointments Appointment[]        @relation("AppointmentPrimaryService")

  @@unique([clinicId, code])
  @@index([clinicId, isActive])
  @@index([clinicId, category])
}

model ServiceOnDoctor {
  doctorId            String
  serviceId           String
  priceOverride       Int?
  // Per-doctor duration override. null = use Service.durationMin. Lets a
  // senior doctor book longer slots for the same nominal service.
  durationMinOverride Int?
  doctor              Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service             Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
  @@index([serviceId])
}

model Cabinet {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  number    String
  floor     Int?
  nameRu    String?
  nameUz    String?
  equipment String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-reference to the doctor occupying this cabinet, if any. Optional
  // because there's a brief window during onboarding/reassignment when a
  // cabinet exists with no doctor yet attached.
  doctor       Doctor?
  appointments Appointment[]

  @@unique([clinicId, number])
  @@index([clinicId, isActive])
  @@index([clinicId, branchId])
}

model DoctorSchedule {
  id        String    @id @default(cuid())
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  weekday   Int
  startTime String
  endTime   String
  validFrom DateTime?
  validTo   DateTime?
  isActive  Boolean   @default(true)

  @@index([clinicId, doctorId, weekday])
  @@index([clinicId, branchId])
}

model DoctorTimeOff {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([clinicId, doctorId, startAt])
  @@index([clinicId, branchId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Patients & Appointments
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Patient {
  id                 String               @id @default(cuid())
  clinicId           String
  clinic             Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // Per-clinic human-readable patient number. Allocated atomically at
  // creation via Clinic.patientCounter; rendered as "P-00125" everywhere
  // the patient is shown (cards, invoices, receipts, call-center).
  patientNumber      Int
  fullName           String
  phone              String
  phoneNormalized    String
  birthDate          DateTime?
  gender             Gender?
  passport           String?
  address            String?
  photoUrl           String?
  telegramId         String?
  telegramUsername   String?
  // Telegram inbox enrichment (TZ-telegram-section.md).
  // `tgBlockedAt` вҖ” set when the patient blocks the bot (webhook
  // `my_chat_member` kicked/left, or a 403 send-fallback); cleared on
  // unblock / `/start`. Drives the В«Р·Р°РұР»РҫРәРёСҖРҫРІР°Р»РёВ» stat + broadcast exclusion.
  // `telegramLinkedAt` вҖ” first time `telegramId` was stamped; powers the
  // В«+N Р·Р° РҪРөРҙРөР»СҺВ» trend.
  tgBlockedAt        DateTime?
  telegramLinkedAt   DateTime?
  preferredChannel   CommunicationChannel @default(TG)
  preferredLang      Lang                 @default(RU)
  source             LeadSource?
  segment            PatientSegment       @default(NEW)
  tags               String[]
  notes              String?              @db.Text
  ltv                Int                  @default(0)
  visitsCount        Int                  @default(0)
  balance            Int                  @default(0)
  discountPct        Int                  @default(0)
  lastVisitAt        DateTime?
  nextVisitAt        DateTime?
  // Most-recent operator-driven contact (any direction): manual SMS/email,
  // telegram message, voice call, completed visit. Excludes automated template
  // sends вҖ” those are mechanical, not a "we got in touch" signal. Maintained
  // by `bumpPatientLastContact` at every write site; backfilled by the
  // accompanying migration. Indexed for the dormant-contact segment query.
  lastContactedAt    DateTime?
  consentMarketing   Boolean              @default(false)
  // Phase 14 вҖ” Revenue Engines.
  // `dormantSince` is stamped by a future engine when the patient crosses an
  // inactivity threshold (no visit/contact within window). `reactivationSentAt`
  // accumulates timestamps for each reactivation campaign send so the engine
  // can enforce once-per-quarter idempotency without a join table.
  dormantSince       DateTime?
  reactivationSentAt DateTime[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Phase 15 Wave 1 вҖ” LLM-generated patient summary.
  // `summaryCache` holds the latest auto-summary (last visit highlights,
  // active diagnoses, free-text alerts) shown on the patient card. Wave 2
  // populates it; Wave 1 just reserves the columns. `summaryCacheUpdatedAt`
  // is the cache timestamp used to invalidate on new visit / new note.
  summaryCache          String?   @db.Text
  summaryCacheUpdatedAt DateTime?

  // Phase 17 Wave 1 вҖ” Compliance & Trust.
  // `marketingOptOut` is the explicit opt-OUT flag (NOT the same as
  // `consentMarketing` opt-IN). When TRUE, marketing-classified pushes
  // (reactivation, NPS, medication reminders, birthday, referral reward,
  // etc.) are blocked by the consent-gate helper at every send-site.
  // Transactional pushes (appointment confirmation, 24h/5h/2h reminders,
  // appointment.cancelled, pre-visit questionnaire) are NEVER gated.
  // `marketingOptOutSource` records who/what set the flag вҖ” the Mini App
  // toggle, an inbound SMS STOP keyword, an admin action, or a future
  // data-deletion request.
  marketingOptOut       Boolean   @default(false)
  marketingOptOutAt     DateTime?
  marketingOptOutSource String?
  // Soft-delete plumbing for Wave 3 DSAR support. `deletedAt` makes the
  // patient invisible to all sends regardless of kind. The deletion path
  // itself (admin approval + actual scrubbing) lands in Wave 3 вҖ” Wave 1
  // just reserves the columns so the consent-gate helper can already
  // honour them and we don't need a second migration in Wave 3.
  deletedAt             DateTime?
  deletionRequestedAt   DateTime?
  deletionReason        String?

  appointments              Appointment[]
  payments                  Payment[]
  conversations             Conversation[]
  calls                     Call[]
  notifications             NotificationSend[]
  documents                 Document[]
  communications            Communication[]
  onlineRequests            OnlineRequest[]
  reviews                   Review[]
  leads                     Lead[]
  cases                     MedicalCase[]
  patientReviews            PatientReview[]
  ownedFamilyLinks          PatientFamily[]           @relation("PatientFamilyOwner")
  linkedFamilyLinks         PatientFamily[]           @relation("PatientFamilyLinked")
  prescriptions             Prescription[]
  referralCodes             ReferralCode[]
  referralRewardsAsReferrer ReferralReward[]          @relation("ReferralRewardReferrer")
  referralRewardsAsReferred ReferralReward[]          @relation("ReferralRewardReferred")
  medicationReminderSends   MedicationReminderSend[]
  patientViews              PatientView[]
  dataExportJobs            DataExportJob[]
  dataDeletionJobs          DataDeletionJob[]
  allergies                 PatientAllergy[]
  chronicConditions         PatientChronicCondition[]
  diagnoses                 PatientDiagnosis[]
  telegramInviteTokens      TelegramInviteToken[]
  visitNotes                VisitNote[]
  reminders                 Reminder[]
  labResults                LabResult[]
  labOrders                 LabOrder[]
  ePrescriptions            EPrescription[]
  sickLeaves                SickLeave[]
  cdsOverrides              CdsOverride[]
  referrals                 Referral[]

  @@unique([clinicId, phoneNormalized])
  @@unique([clinicId, patientNumber])
  @@index([clinicId, fullName])
  @@index([clinicId, segment])
  @@index([clinicId, lastVisitAt])
  @@index([clinicId, lastContactedAt])
  @@index([clinicId, createdAt])
  @@index([clinicId, telegramId])
}

model Appointment {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  cabinetId String?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id])

  // Primary service (denormalized for fast filters); additional services live in AppointmentService join.
  serviceId      String?
  primaryService Service? @relation("AppointmentPrimaryService", fields: [serviceId], references: [id])

  date        DateTime
  time        String?
  durationMin Int      @default(30)
  endDate     DateTime

  // Human-readable globally-unique short code (Crockford base32, 6 chars)
  // shown on the booking confirmation screen and encoded in the patient's
  // QR. Nullable in the column so the backfill migration can populate
  // existing rows; new rows are always set by `bookAppointment`.
  ticketCode String? @unique

  status       AppointmentStatus @default(BOOKED)
  queueStatus  AppointmentStatus @default(BOOKED)
  queueOrder   Int?
  // Manual urgency bump for the live queue (Wave 5). Higher floats to the top
  // of the waiting list ahead of arrival order; ties fall back to `queueOrder`
  // (the receptionist's drag order), so a manual reorder is never clobbered.
  // 0 = normal. Set from the reception queue panel.
  queuePriority Int     @default(0)
  // Variant C вҖ” immutable ticket sequence. `queueOrder` is mutated by the
  // reception drag-reorder, which would churn the patient-facing ticket number.
  // `ticketSeq` is frozen at allocation (walk-in / check-in) and is the sole
  // input to `ticketNumberFor`, so a reorder never reassigns a printed ticket.
  // Nullable: set the moment a slot enters the live queue; backfilled from
  // queueOrder for pre-existing rows.
  ticketSeq    Int?
  // serveAt EDF вҖ” the instant this visit joined the live waiting queue. Stamped
  // the moment a row enters WAITING (walk-in registration, kiosk/reception
  // check-in). The queue comparator serves walk-ins FIFO by this stamp and
  // scheduled visits at max(slot, queuedAt) вҖ” so a late booking is treated as a
  // walk-in from arrival and can't jump the people who actually waited. A
  // skipped patient who returns re-joins at the back (fresh stamp); an
  // IN_PROGRESSвҶ’WAITING put-back keeps its original stamp. Null until the row
  // first enters the queue (backfilled for pre-existing live rows).
  queuedAt     DateTime?
  // Wave 3c вҖ” patient tapped В«РҜ РҪР° РјРөСҒСӮРөВ» in the Mini App. Idempotency
  // anchor for self check-in (one patient.arrived event per visit) and the
  // cross-session source of truth for the "you're checked in" pill. NOT a
  // status change: intake (вҶ’ WAITING) stays a receptionist action.
  arrivedAt    DateTime?
  calledAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  // Cross-surface sync v1 (Phase A) вҖ” who initiated the cancel. Free-form
  // string ("patient" | "staff" | "system" | "no-show") so future actors
  // (e.g. payment-failure-auto-cancel) don't need a migration.
  cancelledBy  String?

  // Pre-visit confirmation audit. `status === CONFIRMED` answers "is it
  // confirmed right now"; these three fields answer "when / by whom / how"
  // so reports, dedupe of confirm-call tasks, and metrics ("avg time from
  // booking to confirmation by channel") can read history directly instead
  // of replaying the AuditLog. Set together via `confirmAppointment()`.
  // `confirmedBy` is null for BOOKING_AUTO (channel = PHONE/KIOSK) and for
  // SMS_REPLY / TG_BUTTON (acted on behalf of patient, not staff).
  confirmedAt     DateTime?
  confirmedBy     String?
  confirmedVia    ConfirmationVia?
  confirmedByUser User?            @relation("AppointmentConfirmer", fields: [confirmedBy], references: [id])

  // Optional grouping into a MedicalCase (episode of care). Nullable вҖ”
  // appointments may be one-off without a case. onDelete: SetNull keeps
  // the appointment row alive if its case is deleted.
  medicalCaseId String?
  medicalCase   MedicalCase? @relation(fields: [medicalCaseId], references: [id], onDelete: SetNull)

  channel ChannelType @default(WALKIN)
  leadId  String?     @unique
  lead    Lead?       @relation(fields: [leadId], references: [id])

  priceService   Int?
  priceBase      Int?
  discountPct    Int  @default(0)
  discountAmount Int  @default(0)
  priceFinal     Int?

  createdById String?
  createdBy   User?   @relation("AppointmentCreator", fields: [createdById], references: [id])
  comments    String? @db.Text
  notes       String? @db.Text

  // Phase 16 Wave 2 вҖ” pre-visit questionnaire (24h before).
  // `preVisitData` is a free-form JSON blob shaped by the `PreVisitData`
  // alias in `src/lib/patient-experience/pre-visit.ts` (complaints, allergies,
  // medications, notes, locale). `preVisitNotifiedAt` is the dedupe stamp set
  // when the worker enqueues the TG push so a re-tick within the 23вҖ“25h
  // window doesn't send a second notification. `preVisitSubmittedAt` is set
  // by the Mini App submit endpoint.
  preVisitData        Json?
  preVisitNotifiedAt  DateTime?
  preVisitSubmittedAt DateTime?
  // Phase 16 Wave 2 вҖ” post-visit NPS push dedupe stamp. Set by the
  // `post-visit-nps` worker when it enqueues the request push, prevents the
  // hourly tick from spamming the same patient.
  npsRequestedAt      DateTime?

  services       AppointmentService[]
  payments       Payment[]
  documents      Document[]
  conversation   Conversation?
  patientReviews PatientReview[]
  visitNote      VisitNote?
  reminders      Reminder[]
  labResults     LabResult[]
  labOrders      LabOrder[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  eprescriptions EPrescription[]
  sickLeaves     SickLeave[]

  // A referral can name this appointment as the booked follow-up. Not @unique
  // (one slot could, in theory, fulfil more than one referral), so it's a list.
  scheduledReferrals Referral[]    @relation("ReferralScheduledAppointment")
  cdsOverrides       CdsOverride[]

  @@index([clinicId, date])
  @@index([clinicId, doctorId, date])
  @@index([clinicId, patientId])
  @@index([clinicId, status])
  @@index([clinicId, queueStatus])
  @@index([clinicId, endDate, cabinetId])
  @@index([clinicId, createdAt])
  @@index([clinicId, branchId])
  @@index([clinicId, medicalCaseId])
  // Confirmation-window detectors hit this thousands of times per scheduler
  // tick: "appointments in [now+window-О”, now+window] with confirmedAt IS NULL
  // and status = BOOKED". Composite (clinicId, date, confirmedAt) keeps the
  // scan bounded; partial-index on (confirmedAt IS NULL) would be tighter
  // but Prisma doesn't model partial indexes вҖ” the planner handles it well
  // enough on the composite alone.
  @@index([clinicId, date, confirmedAt])
}

model AppointmentService {
  clinicId      String
  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  priceSnap     Int
  quantity      Int         @default(1)

  @@id([appointmentId, serviceId])
  @@index([clinicId, appointmentId])
  @@index([serviceId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// MedicalCase вҖ” an episode of care that groups 1..N appointments around a
// single complaint/issue. Multiple parallel cases per patient are normal
// (e.g., back pain + pregnancy = two separate cases). Visit number within a
// case is implicit by ORDER BY appointment.startAt. Appointments may exist
// without a case (one-off visits) вҖ” Appointment.medicalCaseId is nullable.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model MedicalCase {
  id               String     @id @default(cuid())
  clinicId         String
  clinic           Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId        String
  patient          Patient    @relation(fields: [patientId], references: [id])
  // Primary doctor responsible for the case. Nullable вҖ” a case may be
  // multi-doctor or unassigned at creation. SetNull on doctor delete so
  // the case is preserved.
  primaryDoctorId  String?
  primaryDoctor    Doctor?    @relation(fields: [primaryDoctorId], references: [id], onDelete: SetNull)
  title            String
  status           CaseStatus @default(OPEN)
  primaryComplaint String?    @db.Text
  diagnosisText    String?    @db.Text
  // Reserved for ICD-10 (or local ICD-equivalent) вҖ” schema-only, no UI yet.
  diagnosisCode    String?
  notes            String?    @db.Text
  // Phase 15 Wave 1 вҖ” voice-transcribed SOAP draft.
  // Populated by the WhisperвҶ’LLM worker (Wave 3) from doctor TG voice notes;
  // doctor edits the draft on the case page. Wave 1 just reserves the column.
  soapDraft        String?    @db.Text
  openedAt         DateTime   @default(now())
  closedAt         DateTime?
  closedReason     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  appointments      Appointment[]
  notificationSends NotificationSend[]
  prescriptions     Prescription[]

  @@index([clinicId, patientId, status])
  @@index([clinicId, status, openedAt])
  @@index([clinicId, primaryDoctorId, status])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// VisitNote вҖ” doctor's per-appointment SOAP / structured note. One per
// Appointment (1:1, unique appointmentId). The reception screen reads/writes
// this row continuously while consultation is active; finalize transitions
// status вҶ’ FINALIZED and is paired with Appointment.status вҶ’ COMPLETED.
//
// Multi-tenant via clinicId. ICD-10 lives in two flat columns rather than a
// FK so we can ship without a coded reference table; a separate ICD lookup
// table can land later without breaking existing rows.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model VisitNote {
  id            String      @id @default(cuid())
  clinicId      String
  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])

  status      VisitNoteStatus @default(DRAFT)
  startedAt   DateTime?
  finalizedAt DateTime?

  // РӨ0 вҖ” human-readable conclusion number ("NF-2026-000123"), allocated
  // atomically inside the finalize transaction via DocumentCounter. Printed
  // in the conclusion header; copied to Document.number by the handout worker.
  documentNumber String?

  // Structured fields. Stored as String[] so chips can be added/removed
  // without rewriting the whole array shape in the editor.
  complaints    String[] @default([])
  anamnesis     String[] @default([])
  examination   String[] @default([])
  prescriptions String[] @default([])
  advice        String[] @default([])

  // Diagnosis (ICD-10). Code is the canonical key; name is a denormalized
  // copy for display so the editor doesn't need a lookup roundtrip.
  diagnosisCode String?
  diagnosisName String?

  // РӨ6 (TZ-smart-constructor) вҖ” follow-up plan. Prefilled from the diagnosis
  // guide / protocol, hand-editable. On finalize: printed in the conclusion,
  // surfaces a booking nudge in the Mini App, and spawns a reception Action.
  followUpDays Int?
  followUpNote String?
  // РӨ6 вҖ” convergence anchor for the medication-bridge sweep: null = the
  // finalize worker hasn't mirrored remindPatient rows into Prescription yet.
  medicationsBridgedAt DateTime?

  // РӨ7 вҖ” СҒРҫСҒСӮРҫСҸРҪРёРө vs РҝСҖРҫСҲР»СӢР№ РІРёР·РёСӮ: IMPROVED | STABLE | WORSE. String not
  // enum (РәР°Рә PatientAllergy.severity) вҖ” РҪРҫРІСӢРө РіСҖР°РҙР°СҶРёРё РұРөР· РјРёРіСҖР°СҶРёРё.
  dynamics     String?
  dynamicsNote String?

  // РӨ8 вҖ” РәР°СҖСӮР° СӮРөР»Р°: [{ x, y, view: FRONT|BACK, label? }], РәРҫРҫСҖРҙРёРҪР°СӮСӢ
  // РҪРҫСҖРјРёСҖРҫРІР°РҪСӢ 0..1 РҫСӮРҪРҫСҒРёСӮРөР»СҢРҪРҫ SVG-С„РёРіСғСҖСӢ. РҹСғСҒСӮРҫР№ РјР°СҒСҒРёРІ = СӮРҫСҮРөРә РҪРөСӮ.
  bodyMap Json?

  // Free-form rich body in Markdown. The notes editor on the right is the
  // canonical source; the structured chips are the parsed/derived view.
  bodyMarkdown String? @db.Text

  // Patient-facing handout in Markdown. Composed by the manual templating
  // composer (no LLM) from the structured fields, then editable by the
  // doctor before print. Independent from bodyMarkdown (clinical record):
  // the printed handout never includes РңРҡР‘ codes or technical anamnesis.
  patientHandoutMarkdown String? @db.Text

  // Provenance вҖ” set when any field was AI-generated and never cleared by
  // edits. Used by audit + UI ("СҒРіРөРҪРөСҖРёСҖРҫРІР°РҪРҫ AI" badge).
  aiGenerated Boolean @default(false)
  aiModel     String?
  aiTokens    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  labResults         LabResult[]
  labOrders          LabOrder[]
  ePrescriptions     EPrescription[]
  sickLeaves         SickLeave[]
  cdsOverrides       CdsOverride[]
  // The patient-facing CONCLUSION handout, generated on finalize. 1:1 вҖ”
  // see Document.visitNoteId (@unique). Null until the worker renders it.
  conclusionDocument Document?
  // Referrals authored from this visit (snapshot the visit's diagnosis).
  referrals          Referral[]
  // РӨ2 (TZ-smart-constructor) вҖ” structured prescription rows on the Drug
  // catalog. `prescriptions String[]` above stays as read-only legacy.
  visitPrescriptions VisitPrescription[]
  // РӨ6 вҖ” Mini App reminder courses mirrored from visitPrescriptions.
  bridgedPrescriptions Prescription[]

  @@index([clinicId, doctorId, status])
  @@index([clinicId, patientId, finalizedAt])
}

// РӨ2 (TZ-smart-constructor) вҖ” structured prescriptions.
enum MealRelation {
  BEFORE_MEAL
  WITH_MEAL
  AFTER_MEAL
  EMPTY_STOMACH
  NO_MATTER
}

model VisitPrescription {
  id          String    @id @default(cuid())
  clinicId    String
  visitNoteId String
  visitNote   VisitNote @relation(fields: [visitNoteId], references: [id], onDelete: Cascade)
  // null = manual entry outside the catalog (free-text fallback is a hard
  // requirement вҖ” the catalog never blocks prescribing).
  drugId      String?
  drug        Drug?     @relation(fields: [drugId], references: [id])
  // Snapshot (В«РҡРҫРҪРәРҫСҖ (РұРёСҒРҫРҝСҖРҫР»РҫР»)В») so print stays stable across catalog edits.
  displayName String
  form        String? // from Drug.forms
  strength    String? // "5 РјРі"
  dose        String // "1 СӮР°Рұ", "10 РјР»"
  // MORNING | NOON | EVENING | NIGHT
  timesOfDay    String[]     @default([])
  mealRelation  MealRelation @default(NO_MATTER)
  durationDays  Int?
  // Auto-filled from Drug.defaultDosing / the guide, then hand-editable.
  instructionRu String?      @db.Text
  instructionUz String?      @db.Text
  // Bridge into patient reminders (РӨ6).
  remindPatient Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([clinicId, visitNoteId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Payments
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Payment {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])

  currency       Currency      @default(UZS)
  amount         Int // minor units of `currency`
  amountUsdSnap  Int? // snapshot in USD cents at payment time
  fxRate         Decimal?      @db.Decimal(12, 4)
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  receiptNumber  String?
  receiptUrl     String?
  refundedAmount Int           @default(0)
  paidAt         DateTime?
  externalRef    String?
  /// Client-supplied idempotency key. Null = retries can dedupe themselves
  /// however they want; non-null = unique per clinic so a network retry with
  /// the same key returns the original row instead of creating a duplicate.
  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, idempotencyKey], map: "Payment_clinicId_idempotencyKey_key")
  @@index([clinicId, status])
  @@index([clinicId, paidAt])
  @@index([clinicId, appointmentId])
  @@index([clinicId, patientId])
  @@index([clinicId, createdAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Documents
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

// Per-clinic, per-year monotonic counters behind human-readable document
// numbers ("NF-2026-000123"). One row per (clinic, year, kind); allocation is
// createMany(skipDuplicates) + atomic increment вҖ” see
// src/server/services/document-number.ts.
model DocumentCounter {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  year      Int
  kind      String
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([clinicId, year, kind])
}

model Document {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  // Set only for auto-generated CONCLUSION handouts. Unique so the
  // visit-note-handout worker can upsert idempotently вҖ” a re-run (sweep
  // retry, redeploy) never plants a duplicate conclusion for the same note.
  visitNoteId   String?      @unique
  visitNote     VisitNote?   @relation(fields: [visitNoteId], references: [id], onDelete: SetNull)
  // Set only for auto-generated REFERRAL PDFs. Unique so the referral-pdf
  // worker upserts idempotently вҖ” same guarantee as visitNoteId above.
  referralId    String?      @unique
  referral      Referral?    @relation(fields: [referralId], references: [id], onDelete: SetNull)
  type          DocumentType
  title         String
  // РӨ0 вҖ” human-readable number ("NF-2026-000123"). For CONCLUSION documents
  // this is copied from VisitNote.documentNumber by the handout worker.
  number        String?
  // РӨ5 вҖ” public QR verification: /v/[token] shows type/number/date with the
  // patient masked to initials. Generated by the handout worker on creation
  // (and backfilled for legacy conclusion docs).
  verifyToken   String?      @unique
  fileUrl       String
  mimeType      String?
  sizeBytes     Int?
  uploadedById  String?
  uploadedBy    User?        @relation("DocumentUploader", fields: [uploadedById], references: [id])
  // CONSENT/CONTRACT signature capture. NULL = awaiting signature; the
  // "РҫР¶РёРҙР°СҺСӮ РҝРҫРҙРҝРёСҒРё" filter keys off this. Stamped by POST .../[id]/sign.
  signedAt      DateTime?
  createdAt     DateTime     @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, type])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Referrals (РҪР°РҝСҖР°РІР»РөРҪРёСҸ) вҖ” a doctor sends a patient onward, either to an
// internal colleague (toDoctorId) or an outside clinic/specialty (externalTo,
// free text). diagnosisCode/diagnosisName are snapshotted from the originating
// visit so the referral stays truthful even if the note is later re-coded.
// A REFERRAL Document PDF is rendered async and linked 1:1 via Document.referralId.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ReferralStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Referral {
  id           String     @id @default(cuid())
  clinicId     String
  clinic       Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id])
  // Author. Points at User (not Doctor) вҖ” the mutation gate is "is this the
  // assigned user?", mirroring LabResult.doctorId / Reminder.doctorId.
  fromDoctorId String
  fromDoctor   User       @relation("ReferralFromDoctor", fields: [fromDoctorId], references: [id])
  // Internal target colleague (optional). Null for an external referral.
  toDoctorId   String?
  toDoctor     User?      @relation("ReferralToDoctor", fields: [toDoctorId], references: [id])
  // External clinic / specialty as free text, used when toDoctorId is null.
  externalTo   String?
  // Originating visit (optional вҖ” a referral can be raised outside a visit).
  visitNoteId  String?
  visitNote    VisitNote? @relation(fields: [visitNoteId], references: [id], onDelete: SetNull)

  reason        String         @db.Text
  diagnosisCode String? // ICD-10 snapshot at the moment of referral
  diagnosisName String?
  status        ReferralStatus @default(PENDING)

  // The follow-up appointment booked off this referral, if any.
  scheduledAppointmentId String?
  scheduledAppointment   Appointment? @relation("ReferralScheduledAppointment", fields: [scheduledAppointmentId], references: [id], onDelete: SetNull)

  // The rendered PDF handout (1:1, async). Back-side of Document.referralId.
  document Document?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, toDoctorId, status])
  @@index([clinicId, fromDoctorId, status])
  @@index([patientId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Communications вҖ” lightweight audit trail of all outbound/inbound touches.
// (Chat threads live in Conversation/Message.)
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Communication {
  id        String                 @id @default(cuid())
  clinicId  String
  clinic    Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId String?
  patient   Patient?               @relation(fields: [patientId], references: [id])
  channel   CommunicationChannel
  direction CommunicationDirection
  subject   String?
  body      String?                @db.Text
  meta      Json?
  createdAt DateTime               @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, channel, createdAt])
}

model Conversation {
  id               String               @id @default(cuid())
  clinicId         String
  clinic           Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  channel          CommunicationChannel
  mode             ConversationMode     @default(bot)
  patientId        String?
  patient          Patient?             @relation(fields: [patientId], references: [id])
  appointmentId    String?              @unique
  appointment      Appointment?         @relation(fields: [appointmentId], references: [id])
  externalId       String?
  contactFirstName String?
  contactLastName  String?
  contactUsername  String?
  status           ConversationStatus   @default(OPEN)
  assignedToId     String?
  assignedTo       User?                @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  tags             String[]
  lastMessageAt    DateTime?
  lastMessageText  String?
  unreadCount      Int                  @default(0)
  snoozedUntil     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  messages Message[]

  @@unique([clinicId, externalId])
  @@index([clinicId, status, lastMessageAt])
  @@index([clinicId, assignedToId, status])
  @@index([clinicId, patientId])
}

model Message {
  id             String           @id @default(cuid())
  clinicId       String
  clinic         Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  body           String?          @db.Text
  attachments    Json?
  buttons        Json?
  senderId       String?
  sender         User?            @relation("MessageSender", fields: [senderId], references: [id])
  status         MessageStatus    @default(SENT)
  externalId     String?
  replyToId      String?
  createdAt      DateTime         @default(now())

  @@unique([clinicId, externalId])
  @@index([clinicId, conversationId, createdAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Notifications & Campaigns
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model NotificationTemplate {
  id            String               @id @default(cuid())
  clinicId      String
  clinic        Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  key           String
  nameRu        String
  nameUz        String
  channel       CommunicationChannel
  category      TemplateCategory
  bodyRu        String               @db.Text
  bodyUz        String               @db.Text
  buttons       Json?
  variables     String[]
  trigger       NotificationTrigger  @default(MANUAL)
  triggerConfig Json?
  isActive      Boolean              @default(true)
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  sends     NotificationSend[]
  campaigns Campaign[]

  @@unique([clinicId, key])
  @@index([clinicId, category])
  @@index([clinicId, isActive])
}

model NotificationSend {
  id            String                @id @default(cuid())
  clinicId      String
  clinic        Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  templateId    String?
  template      NotificationTemplate? @relation(fields: [templateId], references: [id])
  campaignId    String?
  campaign      Campaign?             @relation(fields: [campaignId], references: [id])
  patientId     String
  patient       Patient               @relation(fields: [patientId], references: [id])
  appointmentId String?
  caseId        String?
  case          MedicalCase?          @relation(fields: [caseId], references: [id], onDelete: SetNull)
  channel       CommunicationChannel
  recipient     String
  body          String                @db.Text
  status        NotificationStatus    @default(QUEUED)
  scheduledFor  DateTime
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failedReason  String?
  externalId    String?
  retryCount    Int                   @default(0)
  createdAt     DateTime              @default(now())

  @@index([clinicId, status, scheduledFor])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, campaignId])
  @@index([clinicId, caseId, templateId])
  @@index([patientId, channel, status, readAt])
}

model Campaign {
  id           String                @id @default(cuid())
  clinicId     String
  clinic       Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name         String
  templateId   String?
  template     NotificationTemplate? @relation(fields: [templateId], references: [id])
  body         String?               @db.Text // inline broadcast body (used when templateId is null)
  segment      Json? // filter definition
  channel      CommunicationChannel
  status       String                @default("DRAFT")
  scheduledFor DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  totalCount   Int                   @default(0)
  sentCount    Int                   @default(0)
  failedCount  Int                   @default(0)
  createdById  String?
  createdBy    User?                 @relation("CampaignCreator", fields: [createdById], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  sends NotificationSend[]

  @@index([clinicId, status, scheduledFor])
  @@index([clinicId, createdAt])
}

/// Canned (quick-reply) responses for the Telegram inbox composer
/// (TZ-telegram-section.md Layer 4). Clinic-scoped, language-tagged so the
/// picker shows phrases matching the patient's `preferredLang`. `createdById`
/// is a plain scalar (no back-relation on User needed вҖ” we never navigate it).
model CannedResponse {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.Text
  lang        Lang     @default(RU)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId, lang, sortOrder])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Call center / Online requests / Reviews
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Call {
  id            String        @id @default(cuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  direction     CallDirection
  status        CallStatus?
  fromNumber    String
  toNumber      String
  patientId     String?
  patient       Patient?      @relation(fields: [patientId], references: [id])
  operatorId    String?
  operator      User?         @relation("CallOperator", fields: [operatorId], references: [id])
  appointmentId String?
  durationSec   Int?
  recordingUrl  String?
  summary       String?       @db.Text
  tags          String[]
  sipCallId     String?
  createdAt     DateTime      @default(now())
  startedAt     DateTime?
  answeredAt    DateTime?
  endedAt       DateTime?

  @@unique([clinicId, sipCallId])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, operatorId, createdAt])
  @@index([clinicId, direction, createdAt])
  @@index([clinicId, status, createdAt])
}

model OnlineRequest {
  id          String      @id @default(cuid())
  clinicId    String
  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  service     String?
  doctorId    String?
  preferredAt DateTime?
  channel     ChannelType
  status      LeadStatus  @default(NEW)
  source      LeadSource  @default(WEBSITE)
  utm         Json?
  comment     String?     @db.Text
  patientId   String?
  patient     Patient?    @relation(fields: [patientId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
}

// Legacy-compatible lead (form submissions converted into Appointments)
model Lead {
  id                String     @id @default(cuid())
  clinicId          String
  clinic            Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name              String
  phone             String
  service           String?
  date              DateTime?
  doctorId          String?
  doctor            Doctor?    @relation(fields: [doctorId], references: [id])
  patientId         String?
  patient           Patient?   @relation(fields: [patientId], references: [id])
  status            LeadStatus @default(NEW)
  source            LeadSource @default(WEBSITE)
  utm               Json?
  comment           String?    @db.Text
  // Phase 16 Wave 3 вҖ” refer-a-friend attribution. Set when the lead/booking
  // came in through a friend's referral link; combined with `source = REFERRAL`
  // this is what the redemption path keys off of when crediting a reward.
  // SetNull on patient delete so the lead row survives if the referrer
  // patient is removed.
  referrerPatientId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  appointment Appointment?

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
  @@index([clinicId, referrerPatientId])
}

model Review {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  authorName  String
  rating      Int
  text        String   @db.Text
  source      String   @default("yandex")
  sourceUrl   String?
  publishedAt DateTime @default(now())
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId, visible, publishedAt])
  @@index([clinicId, rating])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Audit log
// NOTE: AuditLog has clinicId for reporting/filtering, but is intentionally
// EXCLUDED from the Prisma multi-tenant middleware allowlist so system actions
// can always be recorded even in cross-tenant or SUPER_ADMIN contexts.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String?
  clinic     Clinic?  @relation(fields: [clinicId], references: [id])
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  actorRole  String?
  actorLabel String?
  action     String
  entityType String
  entityId   String?
  meta       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Cross-surface sync v1 (Phase A) вҖ” link audit row to the realtime event
  // that caused it, the surface it originated from, and a correlation id so
  // a single user action can be traced across all surfaces & cascades.
  // All nullable for backwards compat вҖ” only outbox-pumper writes them today.
  eventId       String? @unique
  surface       String?
  correlationId String?

  @@index([clinicId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([correlationId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// EventOutbox вҖ” durable write-ahead log for realtime events (Phase A).
//
// Domain mutations insert a PENDING row inside the same Prisma transaction as
// their writes. A background pumper picks up PENDING rows, publishes them to
// the in-process EventBus + Redis (if enabled), and marks them DELIVERED.
//
// This gives at-least-once delivery for SSE consumers and cursor-based replay
// when an EventSource client reconnects with `Last-Event-ID`. See
// `docs/TZ-cross-surface-sync.md` В§5 for the full contract.
//
// `envelope` stores the full EventEnvelope JSON (v2 fields: actor, surface,
// tenantScope, correlationId, causedByEventId). The `auditable:true` events
// get materialised into AuditLog rows by the pumper, with `AuditLog.eventId`
// FK-linking back here.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model EventOutbox {
  id              String       @id @default(cuid())
  correlationId   String
  causedByEventId String?
  clinicId        String
  type            String
  envelope        Json
  createdAt       DateTime     @default(now())
  status          OutboxStatus @default(PENDING)
  deliveredAt     DateTime?
  attempts        Int          @default(0)
  lastError       String?

  // Pumper poll вҖ” narrow PENDING rows per clinic by createdAt.
  @@index([clinicId, status, createdAt])
  // Replay cursor вҖ” `/api/events?since=<eventId>` reads DELIVERED rows after
  // the cursor's createdAt.
  @@index([clinicId, createdAt])
  // Trace cascade вҖ” "show me everything caused by event X".
  @@index([correlationId])
}

enum OutboxStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// PatientView вҖ” PHI access audit (Phase 17 Wave 1)
//
// One row per "user opened / fetched a patient's PHI" event. Wave 1 wires it
// into the patient-detail page, the appointment GET endpoint (drawer reads),
// case-detail GET, and patient export jobs. The audit page on
// /crm/settings/audit?type=patient-view exposes the rows to ADMINs only.
//
// Throttle: the recordPatientView helper de-duplicates the same
// (viewerUserId, patientId, context) tuple inside a 5-minute window so a
// React re-render storm doesn't blow up the table.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model PatientView {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  viewerUserId String
  viewer       User     @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)
  // Snapshot of the viewer's role at the time of the view. The user's role
  // can change later (e.g. demotion); the audit row should reflect what
  // they were when they looked.
  viewerRole   String
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // Where in the CRM the view originated. Free-form String (not enum) so
  // future surfaces can be added without a migration.
  context      String
  // Optional ID of the appointment / case being viewed; null for direct
  // patient.detail loads.
  contextRef   String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, viewerUserId, createdAt])
  @@index([patientId, createdAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Action Center (Phase 13)
//
// `Action` = atomic system recommendation surfaced to a CRM user with a
// deeplink to the corresponding remediation flow. Detectors run in the
// background (Wave 2) and upsert rows here keyed by `dedupeKey`. The UI
// (Wave 3) reads OPEN actions filtered by role, severity, and status.
//
// `dedupeKey` semantics: each detector produces a stable string from the
// payload, e.g. `EMPTY_SLOT_TOMORROW:doctorId=XYZ:slot=2026-05-07T15:00`.
// The `(clinicId, dedupeKey)` UNIQUE constraint ensures duplicate detector
// passes don't spam rows; instead they upsert the existing row and bump
// `updatedAt`. See `src/lib/actions/types.ts` for the discriminated payload
// union and the `dedupeKeyFor` helper.
//
// `payload` is freeform JSON typed by `ActionPayload` in the application
// layer. Currency amounts inside payloads are stored in tiins (UZS minor
// units, x100) to stay consistent with Payment / pricing conventions in the
// rest of the codebase.
//
// `action` style on AuditLog stays a free-form String for this entity too вҖ”
// `status` here is just a STRING, not an enum. See AUDIT_ACTION constants in
// `src/lib/audit-actions.ts` for the lifecycle action names.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Action {
  id           String    @id @default(cuid())
  clinicId     String
  branchId     String?
  type         String // ActionType union вҖ” see src/lib/actions/types.ts
  severity     String // 'low' | 'medium' | 'high' | 'critical'
  payload      Json
  status       String    @default("OPEN") // OPEN | SNOOZED | DISMISSED | DONE | EXPIRED
  assigneeRole String? // 'ADMIN' | 'RECEPTIONIST' (null = any role)
  deeplinkPath String?
  dedupeKey    String // stable per (clinicId, type, payload-discriminator); UNIQUE per clinic
  snoozeUntil  DateTime?
  dismissedAt  DateTime?
  doneAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expiresAt    DateTime?

  clinic Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([clinicId, dedupeKey])
  @@index([clinicId, status, severity])
  @@index([clinicId, type, status])
  @@index([clinicId, assigneeRole, status])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 14 вҖ” Empty slot snapshot (revenue loss analytics).
//
// One row per (doctor, date, hour) when the engine observes that a slot was
// empty. `estimatedRevenueLossUzs` is stored in tiins (minor units, Г—100 of
// soum) вҖ” same convention as Payment.amount and other money columns. The
// engine that populates this lives in Wave 2 (`src/server/revenue/empty-
// slot.ts`); the analytics dashboard that reads it lives in Wave 3.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model EmptySlotSnapshot {
  id                      String   @id @default(cuid())
  clinicId                String
  clinic                  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId                String?
  branch                  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  doctorId                String
  doctor                  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date                    DateTime // calendar date (UTC midnight)
  hour                    Int // 0..23
  estimatedRevenueLossUzs Int // tiins (minor units)
  takenSnapshotAt         DateTime @default(now())

  @@index([clinicId, date])
  @@index([clinicId, doctorId, date])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 15 Wave 1 вҖ” LLM cost / audit row.
//
// One row per LLM proxy call (success OR failure). `useCase` is a short slug
// (e.g. `patient.summary`, `cmdk.search`) вҖ” intentionally a String, not a
// Prisma enum, because Waves 2-4 add slugs incrementally and we don't want to
// migrate the schema each time. `costUzs` is in tiins (minor units, Г—100 of
// soum) so it stays consistent with Payment.amount and other money columns;
// 0 means the cost was unknown / not estimated. `promptHash` is sha256 of the
// already-redacted prompt вҖ” lets us bucket cache hits without storing PII.
// `errorCode` is null on success and one of `'rate_limit'` /
// `'redaction_failure'` / `'provider_error'` otherwise.
//
// AuditLog also gets a parallel `LLM_CALL` row per call (see
// `src/lib/audit-actions.ts`); LLMUsage is the canonical store the rate
// limiter and analytics dashboards read from, AuditLog is the
// human-browsable trail.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model LLMUsage {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // System-initiated calls (cron summaries, voiceвҶ’SOAP worker) leave userId
  // null. User-initiated calls (cmdk search, marketing copy) set it for
  // per-user analytics. No FK back to User to avoid cascade complications
  // when a user is deleted вҖ” the row is kept for billing.
  userId       String?
  useCase      String
  provider     String
  model        String
  promptHash   String
  inputTokens  Int
  outputTokens Int
  costUzs      Int      @default(0)
  latencyMs    Int
  cacheHit     Boolean  @default(false)
  errorCode    String?
  createdAt    DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([clinicId, useCase, createdAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 16 Wave 1 вҖ” Patient Experience.
//
// PatientReview = NPS response (1..10). Distinct from the existing `Review`
// model (which holds public testimonials harvested from Yandex / Google) вҖ”
// this is patient-private feedback collected from the Mini App / TG bot.
//
// PatientFamily = TG-linked patient ("owner") can act on behalf of N other
// patients (children, spouse, parents). Self-link is rejected at app layer
// AND at DB level via a CHECK constraint added in the migration.
//
// Prescription = doctor-issued medication regimen, attached to a MedicalCase.
// Wave 1 is schema-only; Wave 3 builds the reminder pipeline + UI.
//
// ReferralCode = "refer-a-friend" share token, owned by a patient. Wave 1 is
// schema-only; Wave 3 builds generation/redemption.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model PatientReview {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  doctorId       String?
  doctor         Doctor?      @relation(fields: [doctorId], references: [id])
  // 1..10 NPS scale. Validated at app level вҖ” Postgres CHECK added in the
  // migration as belt-and-suspenders.
  score          Int
  comment        String?      @db.Text
  // 'tg-miniapp' | 'tg-bot' | 'manual' вҖ” String for forward-compat (e.g. a
  // future SMS channel) without schema churn.
  source         String
  adminAlerted   Boolean      @default(false)
  adminAlertedAt DateTime?
  respondedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([clinicId, score, respondedAt])
  @@index([clinicId, doctorId, respondedAt])
  @@index([appointmentId])
}

model PatientFamily {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // Owner = the TG-linked patient who can act on behalf of `linkedPatient`.
  // Self-links (owner == linked) are rejected by app code AND a DB CHECK.
  ownerPatientId  String
  ownerPatient    Patient  @relation("PatientFamilyOwner", fields: [ownerPatientId], references: [id], onDelete: Cascade)
  linkedPatientId String
  linkedPatient   Patient  @relation("PatientFamilyLinked", fields: [linkedPatientId], references: [id], onDelete: Cascade)
  // 'child' | 'spouse' | 'parent' | 'other' вҖ” String, not enum (forward-compat).
  relationship    String
  createdAt       DateTime @default(now())

  @@unique([ownerPatientId, linkedPatientId])
  @@index([clinicId, ownerPatientId])
}

model Prescription {
  id               String      @id @default(cuid())
  clinicId         String
  clinic           Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // Optional since РӨ6 (TZ-smart-constructor): rows bridged from the visit
  // constructor have no MedicalCase вҖ” they anchor on visitNoteId instead.
  caseId           String?
  case             MedicalCase? @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // РӨ6 вҖ” provenance of bridged rows. (visitNoteId, visitNoteSortOrder)
  // mirrors the source VisitPrescription row so the finalize sweep upserts
  // idempotently instead of duplicating courses on re-runs.
  visitNoteId        String?
  visitNote          VisitNote? @relation(fields: [visitNoteId], references: [id], onDelete: Cascade)
  visitNoteSortOrder Int?
  // Denormalized for query speed (Wave 3 reminder query: "all active
  // prescriptions for patient X").
  patientId        String
  patient          Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId         String
  doctor           Doctor      @relation(fields: [doctorId], references: [id])
  drugName         String
  // Free-text "500mg 2 СҖР°Р·Р° РІ РҙРөРҪСҢ" вҖ” no structured RxNorm / formulary yet.
  dosage           String
  // { times: ['09:00','21:00'], days: 30, startsAt: ISO } вҖ” kept flexible
  // because Wave 3 may add fields like `daysOfWeek` / `mealRelation` without
  // requiring a schema migration each time.
  schedule         Json
  notes            String?     @db.Text
  // 'ACTIVE' | 'PAUSED' | 'COMPLETED' вҖ” String, not enum (small set, but
  // we may add 'CANCELLED' or 'EXPIRED' in Wave 3 without a migration).
  status           String      @default("ACTIVE")
  remindersEnabled Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  reminderSends MedicationReminderSend[]

  @@unique([visitNoteId, visitNoteSortOrder])
  @@index([clinicId, patientId, status])
  @@index([clinicId, caseId])
}

// Patient medical history вҖ” structured fields shown on the patient card
// "Medical" tab. These are denormalized from MedicalCase / Prescription so
// doctors can see allergies / chronic conditions / persistent diagnoses
// at a glance, independent of any single visit.

model PatientAllergy {
  id         String    @id @default(cuid())
  clinicId   String
  clinic     Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // Substance: drug, food, environmental ("penicillin", "peanuts", "pollen").
  substance  String
  // Free-text reaction ("rash", "anaphylaxis"). Optional.
  reaction   String?
  // 'MILD' | 'MODERATE' | 'SEVERE'. String not enum so we can add levels
  // without a migration.
  severity   String    @default("MILD")
  notes      String?   @db.Text
  // When the allergy was first observed / recorded by the clinic. Optional.
  recordedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([clinicId, patientId])
}

model PatientChronicCondition {
  id        String    @id @default(cuid())
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  // Onset date if known. Free-form notes for context.
  sinceDate DateTime?
  notes     String?   @db.Text
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([clinicId, patientId, isActive])
}

model PatientDiagnosis {
  id          String    @id @default(cuid())
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // ICD-10 code (free-text вҖ” we don't validate against a code list yet
  // because Uzbekistan's MoH publishes its own subset and integrating it
  // is out of scope).
  icd10Code   String?
  label       String
  diagnosedAt DateTime?
  notes       String?   @db.Text
  // 'ACTIVE' | 'RESOLVED'. Resolved diagnoses are still shown for history
  // but visually muted in the UI.
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId, patientId, status])
}

model ReferralCode {
  id                String    @id @default(cuid())
  clinicId          String
  clinic            Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  referrerPatientId String
  referrerPatient   Patient   @relation(fields: [referrerPatientId], references: [id], onDelete: Cascade)
  // Short slug or full uuid вҖ” globally unique so a redemption endpoint can
  // look up by `code` without needing a clinic context.
  code              String    @unique
  useCount          Int       @default(0)
  // null = unlimited. e.g. set to 1 for a single-use friend invite.
  maxUses           Int?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())

  @@index([clinicId, referrerPatientId])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 16 Wave 3 вҖ” Patient Experience (final wave).
//
// MedicationReminderSend = one row per scheduled medication reminder push.
// Sources from `Prescription.schedule.times[]`. Worker (hourly tick) materialises
// rows for the next hour and stamps them as fired. Patient interacts via the
// Mini App medications dashboard and POSTs back TAKEN / SKIPPED / SNOOZED to
// `/api/miniapp/medications/[reminderSendId]/mark`.
//
// ReferralReward = pending or applied refer-a-friend reward. Created when a
// referred patient's first appointment lands in COMPLETED. Auto-applied on the
// referrer's next BOOKED appointment as a percentage discount, then stamped
// `appliedAt`. Expires after 365 days.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model MedicationReminderSend {
  id             String       @id @default(cuid())
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  // Denormalised вҖ” query hot path is "all open reminders for patient X".
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // The exact tick the reminder is anchored to. Worker dedupes via
  // (prescriptionId, scheduledFor) so two ticks in the same hour can't double
  // up.
  scheduledFor   DateTime
  sentAt         DateTime?
  // 'PENDING' | 'TAKEN' | 'SKIPPED' | 'SNOOZED' | 'EXPIRED' вҖ” kept as String for
  // forward-compat (Wave 4 may add 'PARTIAL' / 'NOT_DELIVERED').
  status         String       @default("PENDING")
  respondedAt    DateTime?
  // Snooze: when the patient asks to be reminded again later. The worker
  // skips this row until `snoozeUntil <= now`. Null = no active snooze.
  snoozeUntil    DateTime?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())

  @@unique([prescriptionId, scheduledFor])
  @@index([clinicId, patientId, status])
  @@index([clinicId, status, scheduledFor])
}

model ReferralReward {
  id                   String    @id @default(cuid())
  clinicId             String
  clinic               Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // The patient who shared the link / earns the discount.
  referrerPatientId    String
  referrerPatient      Patient   @relation("ReferralRewardReferrer", fields: [referrerPatientId], references: [id], onDelete: Cascade)
  // The newly-onboarded patient whose first COMPLETED appointment minted
  // this reward.
  referredPatientId    String
  referredPatient      Patient   @relation("ReferralRewardReferred", fields: [referredPatientId], references: [id], onDelete: Cascade)
  // Snapshot of the clinic.referralRewardPercent at issue time, so a later
  // settings change doesn't retroactively rewrite a pending reward.
  rewardPercent        Int
  // 'PENDING' | 'APPLIED' | 'EXPIRED' вҖ” String for forward-compat.
  status               String    @default("PENDING")
  // Set when the reward is consumed against an appointment.
  appliedAt            DateTime?
  appliedAppointmentId String?
  expiresAt            DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // One reward per (referrer, referred) pair вҖ” prevents double-credit on a
  // referred patient who happens to complete two appointments rapidly.
  @@unique([referrerPatientId, referredPatientId])
  @@index([clinicId, referrerPatientId, status])
  @@index([clinicId, status, expiresAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 17 Wave 2 вҖ” Session security.
//
// UserSession = one row per authenticated CRM session. The proxy stamps
// `userSessionId` into a cookie on login (after TOTP if enrolled), and on
// every authenticated request reads (a) the matching row, (b) bumps
// `lastActivityAt`, (c) enforces idle timeout, (d) enforces the 8h forced
// re-rotation window, (e) enforces "1 active session per user" (a fresh
// login deletes prior rows for this user; the prior cookie then fails the
// lookup and is treated as logged-out).
//
// `tokenHash` is sha256 of the long random session token; the plaintext is
// never stored. `clinicId` is denormalised for analytics / auditing - it
// can drift from the user's current clinic on a SUPER_ADMIN impersonation
// flip, which is fine.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model UserSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId       String?
  clinic         Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  tokenHash      String   @unique
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  userAgent      String?
  ip             String?

  @@index([userId])
  @@index([userId, createdAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 17 Wave 3 вҖ” DSAR (Data Subject Access Requests).
//
// Two independent lifecycle tables:
//
//   DataExportJob       вҖ” patient (or admin on their behalf) asks for a
//                         downloadable copy of every PII-bearing row tied
//                         to the patient. The worker bundles a JSON, ZIPs
//                         it with an AES-encrypted body using a generated
//                         passphrase, uploads to MinIO, and delivers the
//                         file via the per-clinic Telegram bot. The
//                         passphrase is shown ONCE in the UI and the
//                         Telegram caption вҖ” only `passphraseHash` is
//                         persisted (bcryptjs).
//
//   DataDeletionJob     вҖ” patient asks to delete their account, or admin
//                         schedules one from the CRM. Default mode is
//                         ANONYMIZE: PII is scrubbed off the Patient row
//                         while aggregate analytics (visit counts, LTV,
//                         payments) survive. HARD_DELETE drops the
//                         Patient row entirely (use only when legally
//                         required вҖ” referential integrity will null
//                         linked rows). The cron runs hourly and only
//                         executes APPROVED jobs whose `scheduledFor`
//                         has passed; the default 90-day delay gives
//                         the patient a cooling-off window in which they
//                         can cancel the request from the Mini App.
//
// Both tables are tenant-scoped (`clinicId`). The export bucket key is
// `exports/<clinicId>/<jobId>.zip` so a clinic can only enumerate its own
// objects via signed URLs.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum DataExportStatus {
  PENDING
  PROCESSING
  READY
  DELIVERED
  FAILED
  EXPIRED
}

enum DataDeletionStatus {
  PENDING_REVIEW
  APPROVED
  CANCELLED
  EXECUTED
  ANONYMIZED
}

enum DataDeletionMode {
  HARD_DELETE
  ANONYMIZE
}

model DataExportJob {
  id                String           @id @default(cuid())
  clinicId          String
  clinic            Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status            DataExportStatus @default(PENDING)
  // Bcryptjs hash of the one-time passphrase used to encrypt the ZIP.
  // The plaintext is shown ONCE (Mini App success modal + TG caption);
  // never persisted. Allowed null only briefly before the worker has
  // generated the passphrase вҖ” typical reads always see a value.
  passphraseHash    String?
  // MinIO object key (`exports/<clinicId>/<jobId>.zip`). Null until the
  // worker has uploaded; permits PENDING / PROCESSING rows without a key.
  storageKey        String?
  fileSizeBytes     Int?
  // Number of times the signed-download endpoint has served this bundle.
  // Bumped atomically; analysed in the audit trail / DSAR queue UI.
  downloadCount     Int              @default(0)
  // Telegram chat that should receive the document. For Mini App requests
  // this is the patient's tgChatId; for CRM-initiated requests it's the
  // admin's chat (so the file lands in the admin's DM, not the patient's).
  telegramChatId    String?
  // Bundle expires (and is purgeable) at this instant. Default 30 days.
  expiresAt         DateTime
  // If a worker step fails, capture the human-readable reason here so the
  // CRM queue UI can surface it without round-tripping to the audit log.
  errorMessage      String?
  // For CRM-initiated exports: the User who clicked "РӯРәСҒРҝРҫСҖСӮ РҙР°РҪРҪСӢС…".
  // Null when the request came from the Mini App.
  requestedByUserId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clinicId, status])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model DataDeletionJob {
  id                String             @id @default(cuid())
  clinicId          String
  clinic            Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId         String
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status            DataDeletionStatus @default(PENDING_REVIEW)
  mode              DataDeletionMode   @default(ANONYMIZE)
  // Earliest moment the cron will execute the job. Default = createdAt + 90d.
  scheduledFor      DateTime
  reason            String?
  // For admin-approved jobs: the User who approved.
  approvedByUserId  String?
  approvedAt        DateTime?
  // For executed jobs: timestamp of actual scrub / hard-delete.
  executedAt        DateTime?
  // For cancellation: who cancelled and when.
  cancelledByUserId String?
  cancelledAt       DateTime?
  cancelReason      String?
  // Free-form note from the requesting actor (Mini App textarea or CRM
  // admin form). Surfaced in the queue UI and the audit `meta`.
  notes             String?            @db.Text
  // For Mini App requests: the patient is the actor. For CRM-initiated
  // requests: the User who created the job.
  requestedByUserId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([clinicId, status])
  @@index([scheduledFor])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 18 Wave 1 вҖ” Analytics & Reporting foundation.
//
// SavedReport / ScheduledReport persist the W3 report-builder configuration
// and the W4 scheduled-delivery cron rows. The `config` JSON shape is owned
// by the W3 builder; W1 only persists it opaquely so the foundation can land
// without dictating UI semantics.
//
// The materialized views (mv_doctor_performance / mv_cohort_retention /
// mv_financial_pace / mv_schedule_heatmap) live in raw SQL inside the
// migration вҖ” Prisma doesn't model materialized views, and the analytics
// resolvers read from them via `$queryRawUnsafe` with parameterized clinicId.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ScheduledReportCadence {
  DAILY
  WEEKLY
  MONTHLY
}

enum ScheduledReportChannel {
  EMAIL
  TELEGRAM
}

model SavedReport {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // The User who built and saved the report. Restrict (not cascade) so
  // accidental user deletion doesn't erase a clinic's saved reports.
  createdByUserId String
  createdBy       User      @relation("SavedReportCreator", fields: [createdByUserId], references: [id])
  name            String
  description     String?
  // Opaque builder config вҖ” the W3 report-builder owns its schema (selected
  // dimensions, measures, filters, chart kind, layout). W1 just persists it.
  config          Json
  // Stamped by the W3 "Run report" path so the list view can sort
  // most-recently-used to the top.
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  scheduledReports ScheduledReport[]

  @@index([clinicId, createdAt(sort: Desc)])
  @@index([createdByUserId])
}

model ScheduledReport {
  id                  String                 @id @default(cuid())
  clinicId            String
  clinic              Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  savedReportId       String
  savedReport         SavedReport            @relation(fields: [savedReportId], references: [id], onDelete: Cascade)
  cadence             ScheduledReportCadence
  // Driver column for the W4 cron picker вҖ” a row is "due" when
  // enabled = true AND nextRunAt <= now(). The cron updates this after
  // each successful delivery (cadence-step ahead).
  nextRunAt           DateTime
  deliveryChannel     ScheduledReportChannel
  // Email address or Telegram chat id. Validation lives at the API layer.
  deliveryTarget      String
  enabled             Boolean                @default(true)
  lastDeliveredAt     DateTime?
  // Last failure reason text вҖ” surfaced in the "Scheduled reports" list
  // so admins can see why a row keeps failing without digging into logs.
  lastFailureReason   String?
  // W4 вҖ” delivery format. Free TEXT (not enum) so future formats (xlsx,
  // html-body) can be added without another migration. Validated at the
  // API layer via zod ("pdf" | "csv" today).
  format              String                 @default("pdf")
  // W4 вҖ” consecutive-failure counter. After 3 in a row the worker disables
  // the schedule and audits SCHEDULED_REPORT_DISABLED_AFTER_FAILURES.
  // Resets to 0 on every successful delivery.
  consecutiveFailures Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([enabled, nextRunAt])
  @@index([clinicId])
  @@index([savedReportId])
}

/// Phase 19 (post-MVP add-on) вҖ” short-lived invite link a staff member
/// mints from the patient card so a not-yet-linked patient can land in
/// the Telegram bot via `t.me/<botUsername>?start=<token>`. The bot
/// webhook parses the `/start <token>` payload, looks up an unconsumed
/// row by `token` scoped to the clinic, stamps `Patient.telegramId` +
/// `telegramUsername`, then marks the token `consumedAt`. Tokens are
/// idempotent: minting twice within the validity window returns the
/// existing row instead of issuing a fresh one.
model TelegramInviteToken {
  id                 String    @id @default(cuid())
  clinicId           String
  clinic             Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId          String
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// URL-safe random string used as the `/start <payload>` argument. Globally
  /// unique to keep the bot lookup a single index hit even when no clinic id
  /// is available at the call site (the bot sees a chat update before it
  /// knows the merchant clinic).
  token              String    @unique
  /// Staff user who created the invite. Nullable so historical / migrated
  /// rows can survive a user delete without breaking the audit join.
  createdByUserId    String?
  createdByUser      User?     @relation("TelegramInviteTokenCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  expiresAt          DateTime
  /// Stamped the first time the bot consumes the token. Nullable rows are
  /// still active; non-null rows are inert and only kept for the audit
  /// trail.
  consumedAt         DateTime?
  /// Telegram user id that consumed the token. Captured for support when
  /// a patient claims they linked the wrong account.
  consumedTelegramId String?

  @@index([clinicId])
  @@index([patientId])
  @@index([expiresAt])
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Phase 20 Wave 5a вҖ” Reminder + LabResult
//
// `Reminder` is the doctor's personal task list ("РҝРҫР·РІРҫРҪРёСӮСҢ РҡР°СҒСӢРјРҫРІСғ",
// "РҝРөСҖРөСҒРҙР°СӮСҢ РһРҗРҡ") surfaced on /doctor/my-day and the Action Center. Owner
// is always a User (DOCTOR role); doctorId/userId distinction is irrelevant
// because the link is 1:1.
//
// `LabResult` is the MVP shape for incoming lab work вҖ” a flat row keyed by
// (patient, doctor, test). When a real lab-system integration lands later
// we layer a `LabOrder` parent without breaking these rows.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ReminderStatus {
  PENDING
  DONE
  DISMISSED
  SNOOZED
}

model Reminder {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // Owning doctor (User row, role=DOCTOR). The list endpoint filters by
  // `doctorId = me`; admins can read clinic-wide.
  doctorId      String
  doctor        User         @relation("DoctorReminders", fields: [doctorId], references: [id])
  // Optional patient context. NULL = "general" reminder unrelated to a
  // specific case (e.g., "РҝРөСҖРөР·РІРҫРҪРёСӮСҢ СҒСӮСҖР°С…РҫРІРҫР№").
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])
  // Optional appointment context вҖ” surfaces this reminder on the visit
  // page and lets us auto-create follow-up reminders from a finalized
  // VisitNote later (no UI today).
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  title       String
  body        String?        @db.Text
  // The wall-clock moment this should pop on My Day. Filtered against
  // `now()` server-side; UTC in storage, formatted in clinic timezone in UI.
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([clinicId, doctorId, status, remindAt])
  @@index([clinicId, patientId])
}

enum LabStatus {
  PENDING
  RESULTED
  REVIEWED
  ARCHIVED
}

enum LabFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL
}

model LabResult {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  // Ordering doctor (User row). The unread-labs feed is filtered by
  // `doctorId = me`; the patient-detail tab shows all labs regardless.
  doctorId      String
  doctor        User         @relation("DoctorLabResults", fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  // Explicit link to the visit note that ordered the test (when the
  // doctor used the В«РҪР°Р·РҪР°СҮРөРҪРёСҸВ» chip flow to create this lab order).
  visitNoteId   String?
  visitNote     VisitNote?   @relation(fields: [visitNoteId], references: [id])

  // Free-text test name; we don't gate on a controlled vocabulary because
  // doctors copy values from paper reports today. `testCode` reserved for
  // LOINC/local once we wire a lab-system integration.
  testName String
  testCode String?
  // Stored as string so we can accept ranges ("3.5-5.5"), qualitative
  // results ("РҝРҫР»РҫР¶РёСӮ."), and free-form annotations without losing them
  // to a Decimal coercion.
  value    String
  unit     String?
  refRange String?
  flag     LabFlag?
  notes    String?  @db.Text

  status        LabStatus @default(PENDING)
  // Stamped server-side at create. The unread feed orders by this DESC.
  receivedAt    DateTime  @default(now())
  reviewedAt    DateTime?
  // userId who flipped status to REVIEWED. No FK relation because we
  // never join вҖ” used for audit display only.
  reviewedBy    String?
  // Optional PDF/scan upload (MinIO key). Wave 5a does not implement the
  // upload UI; the column is reserved so the real integration in Phase 6
  // doesn't need another migration.
  attachmentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, doctorId, status, receivedAt])
  @@index([clinicId, patientId, receivedAt])
}

// Per-doctor notification channel preferences. One row per doctor; the row
// is materialized lazily on first GET of /api/crm/doctors/me/notification-prefs
// so we don't need to backfill on signup. All booleans default to a sensible
// "doctors want to know" set вҖ” in-app is always on for the four core events,
// telegram is on for the noisy events, email is on only for lab results.
//
// Channel naming convention: `<event>_<channel>`. Adding a new event means a
// migration; adding a new channel means many migrations вҖ” fine for v1 (~4 events
// Г— 3 channels). When the matrix grows past 24 cells we'll switch to JSONB.
model DoctorNotificationPref {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointmentCreated_inApp    Boolean @default(true)
  appointmentCreated_email    Boolean @default(false)
  appointmentCreated_telegram Boolean @default(true)

  messageNew_inApp    Boolean @default(true)
  messageNew_email    Boolean @default(false)
  messageNew_telegram Boolean @default(true)

  labResultReceived_inApp    Boolean @default(true)
  labResultReceived_email    Boolean @default(true)
  labResultReceived_telegram Boolean @default(false)

  reminderDue_inApp    Boolean @default(true)
  reminderDue_email    Boolean @default(false)
  reminderDue_telegram Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
