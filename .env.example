# ---------------------------------------------------------------------------
# MedBook / NeuroFax — env template. Copy to `.env` and fill in real values.
# ---------------------------------------------------------------------------
# Keep this file in version control. Never commit your real `.env`.

# -------------------- Postgres --------------------
# When running docker-compose, use the compose hostname `postgres`. For local
# `npm run dev` pointing at a host Postgres, switch to localhost:5432.
POSTGRES_DB=medbook
POSTGRES_USER=medbook
POSTGRES_PASSWORD=change-me-long-random
DATABASE_URL=postgresql://medbook:change-me-long-random@postgres:5432/medbook?schema=public

# -------------------- Redis (BullMQ + SSE fan-out) --------------------
# Empty = fall back to in-memory adapter (single-node dev only).
REDIS_URL=redis://redis:6379

# -------------------- Auth.js (NextAuth v5) --------------------
# Generate: `openssl rand -base64 32`
AUTH_SECRET=change-me-openssl-rand-base64-32
AUTH_URL=https://neurofax.uz

# -------------------- App-level secret for AES-GCM encryption --------------------
# Used by src/server/crypto/secrets.ts for ProviderConnection secrets.
# If unset, falls back to AUTH_SECRET. Generate the same way.
APP_SECRET=change-me-openssl-rand-base64-32

# -------------------- MinIO / S3-compatible storage --------------------
# Empty MINIO_ENDPOINT = dev mode (uploads land in /tmp/uploads).
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=medbook
MINIO_SECRET_KEY=change-me-min-8-chars
MINIO_BUCKET=medbook
# Public URL users hit for signed links — usually the nginx vhost in prod.
MINIO_PUBLIC_URL=https://files.neurofax.uz
# Force path-style addressing (required for MinIO).
MINIO_FORCE_PATH_STYLE=true

# -------------------- Telegram --------------------
# Default token for the SUPER_ADMIN area; per-clinic bots live on Clinic rows.
TELEGRAM_BOT_TOKEN=
# Base URL Telegram calls back into. Usually the production origin.
TG_WEBHOOK_BASE_URL=https://neurofax.uz

# -------------------- SMS gateways --------------------
# Empty = log-only stub. Fill when Eskiz / Playmobile accounts are provisioned.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SENDER=

# -------------------- Observability --------------------
# Empty = Sentry disabled (no-op).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# -------------------- Cron jobs --------------------
# Shared secret for any /api/cron/* endpoints (future).
CRON_SECRET=change-me-hex-32

# -------------------- Backups (ops/backup.sh) --------------------
# Bucket name where nightly pg_dump lands — defaults to MINIO_BUCKET.
BACKUP_BUCKET=medbook-backups
BACKUP_RETENTION_DAYS=30

# -------------------- Deployment --------------------
# Consumed by ops/certbot-init.sh
LETSENCRYPT_EMAIL=ops@neurofax.uz
LETSENCRYPT_DOMAIN=neurofax.uz
