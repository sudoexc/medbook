generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id          String   @id // slug: "busakov", "tyncherova", etc.
  nameRu      String
  nameUz      String
  specialtyRu String
  specialtyUz String
  cabinet     Int
  scheduleRu  String
  scheduleUz  String
  hours       String
  photo       String?
  services    Json     // [{ nameRu, nameUz, price }]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?
  leads        Lead[]
  appointments Appointment[]
  schedules    DoctorSchedule[]
  daysOff      DoctorDayOff[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String?
  name           String?
  role           Role      @default(DOCTOR)
  doctorId       String?   @unique
  doctor         Doctor?   @relation(fields: [doctorId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  doctorId  String?
  doctor    Doctor?    @relation(fields: [doctorId], references: [id])
  service   String?
  date      String?
  locale    String     @default("ru")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  appointment Appointment?
}

model Patient {
  id        String   @id @default(cuid())
  fullName  String
  phone          String   @unique
  passport       String?  @unique
  birthDate      DateTime?
  notes          String?  @db.Text
  telegramChatId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor            @relation(fields: [doctorId], references: [id])
  service     String?
  date        DateTime

  // Queue
  source      AppointmentSource @default(ONLINE)
  queueOrder  Int?
  queueStatus QueueStatus       @default(WAITING)

  // Time tracking
  startedAt   DateTime?
  completedAt DateTime?
  durationMin Int?

  notes       String?           @db.Text
  leadId      String?           @unique
  lead        Lead?             @relation(fields: [leadId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  medicalRecord MedicalRecord?
  payment       Payment?

  @@index([doctorId, date, queueStatus])
}

model MedicalRecord {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  complaints      String?  @db.Text
  diagnosis       String?  @db.Text
  prescriptions   String?  @db.Text
  recommendations String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Int           // in UZS
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  dayOfWeek Int      // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, dayOfWeek])
}

model DoctorDayOff {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@unique([doctorId, date])
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CANCELLED
}

enum AppointmentSource {
  ONLINE
  WALKIN
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  UNPAID
  PAID
}

model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int      // 1-5
  text       String   @db.Text
  source     String   @default("yandex") // yandex, google, manual
  sourceUrl  String?
  publishedAt DateTime @default(now())
  visible    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
