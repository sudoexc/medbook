  "faq": {
    "title": "Ko'p beriladigan savollar",
    "q1": {
      "question": "Qabulga qanday yozilaman?",
      "answer": "Bizga qo'ng'iroq qiling, Telegramga yozing yoki saytda so'rov qoldiring — biz qo'ng'iroq qilib qulay vaqtni tanlaymiz."
    },
    "q2": {
      "question": "EEG uchun tayyorgarlik kerakmi?",
      "answer": "Sochlar toza, lak va gelsiz bo'lishi kerak. Tekshiruvdan oldin yaxshi uxlash tavsiya etiladi."
    },
    "q3": {
      "question": "Bolalarni qabul qilasizlarmi?",
      "answer": "Ha, 6-xonada bolalar nevropatologi va pediatr qabul qiladi. Dushanbadan shanbagacha yozilish mumkin."
    },
    "q4": {
      "question": "Qanday to'lov usullarini qabul qilasiz?",
      "answer": "Naqd pul, Uzcard, Humo, Payme, Click. Qabuldan keyin to'lov."
    },
    "q5": {
      "question": "Qabul qancha davom etadi?",
      "answer": "Konsultatsiya 20-30 daqiqa. EEG — tekshiruv turiga qarab 30 daqiqadan 1 soatgacha."
    }
  },
