// MedBook / NeuroFax — initial multi-tenant schema (Phase 1)
// All operational entities carry clinicId + FK to Clinic.
// Unique keys within a clinic are composite (clinicId, ...).
// Money is stored as Int in minor units (tiyin for UZS, cents for USD).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  NURSE
  CALL_OPERATOR
}

enum Currency {
  UZS
  USD
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  PAYME
  CLICK
  UZUM
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum AppointmentStatus {
  BOOKED
  WAITING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  CANCELLED
  NO_SHOW
}

enum PatientSegment {
  NEW
  ACTIVE
  DORMANT
  VIP
  CHURN
}

enum ChannelType {
  WALKIN
  PHONE
  TELEGRAM
  WEBSITE
  KIOSK
}

enum CommunicationChannel {
  SMS
  TG
  CALL
  EMAIL
  VISIT
  INAPP
}

enum CommunicationDirection {
  IN
  OUT
}

enum ConversationMode {
  bot
  takeover
}

enum TemplateCategory {
  REMINDER
  MARKETING
  TRANSACTIONAL
}

enum Gender {
  MALE
  FEMALE
}

enum Lang {
  RU
  UZ
}

enum ConversationStatus {
  OPEN
  SNOOZED
  CLOSED
}

enum MessageDirection {
  IN
  OUT
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum NotificationTrigger {
  MANUAL
  APPOINTMENT_CREATED
  APPOINTMENT_BEFORE
  APPOINTMENT_MISSED
  APPOINTMENT_COMPLETED
  PATIENT_BIRTHDAY
  PATIENT_INACTIVE_DAYS
  CASE_REPEAT_DUE
  CRON
}

enum CallDirection {
  IN
  OUT
  MISSED
}

enum DocumentType {
  REFERRAL
  PRESCRIPTION
  RESULT
  CONSENT
  CONTRACT
  RECEIPT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CANCELLED
}

enum LeadSource {
  WEBSITE
  TELEGRAM
  INSTAGRAM
  CALL
  WALKIN
  REFERRAL
  ADS
  OTHER
}

enum ProviderKind {
  TELEGRAM
  SMS
  PAYME
  CLICK
  UZUM
  OPENAI
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum CaseStatus {
  OPEN
  RESOLVED
  ABANDONED
  TRANSFERRED
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

model Clinic {
  id                         String    @id @default(cuid())
  slug                       String    @unique
  nameRu                     String
  nameUz                     String
  addressRu                  String?
  addressUz                  String?
  phone                      String?
  email                      String?
  logoUrl                    String?
  brandColor                 String    @default("#3DD5C0")
  timezone                   String    @default("Asia/Tashkent")
  currency                   Currency  @default(UZS)
  secondaryCurrency          Currency?
  exchangeRateToUsd          Decimal?  @db.Decimal(12, 4)
  workdayStart               String    @default("09:00")
  workdayEnd                 String    @default("19:00")
  slotMin                    Int       @default(30)
  tgBotUsername              String?
  tgBotToken                 String?
  tgWebhookSecret            String?
  smsSenderName              String?
  kioskPin                   String?
  active                     Boolean   @default(true)
  // Phase 16 Wave 2 — NPS alert threshold. When a PatientReview lands with
  // `score < npsAlertThreshold`, the NPS submit path emits a LOW_NPS_RECEIVED
  // Action (severity high) and stamps `adminAlerted=true` on the review.
  // Default 7 matches the "promoter / passive / detractor" cutoff. Wave 3
  // exposes this in /crm/settings/clinic.
  npsAlertThreshold          Int       @default(7)
  // Phase 16 Wave 3 — Refer-a-friend reward percentage applied to the
  // referrer's NEXT booking after the referred patient completes their
  // first appointment. 0..50; 0 disables the reward. The Mini App refer
  // page shows this number; the auto-apply logic in booking POST reads it.
  referralRewardPercent      Int       @default(15)
  // Phase 16 Wave 3 — Master switch for medication reminders. When false,
  // the medication-reminder worker skips this clinic entirely. Doctors can
  // still author Prescription rows; their `remindersEnabled` flag is
  // independent so we don't lose existing setup if the master toggle is
  // flipped temporarily.
  medicationRemindersEnabled Boolean   @default(true)
  // Phase 17 Wave 2 — when true, every staff role in the clinic must enrol
  // TOTP, not just ADMIN/SUPER_ADMIN. Plan-gated: only Pro / Enterprise
  // plans can flip this on (Basic UI shows it disabled with an upsell hint).
  // Enforcement lives in the proxy/redirect guard.
  require2faForAll           Boolean   @default(false)
  // Phase 17 Wave 2 — clinic-level idle timeout in minutes. The proxy
  // invalidates a session whose lastActivityAt is older than this. App-level
  // bound is [5, 240]; the schema cannot express that, so the API + form
  // clamp on every write.
  sessionIdleTimeoutMinutes  Int       @default(30)
  // Phase 19 Wave 1 — SaaS self-service.
  // `customSubdomain` lets Pro/Enterprise tenants serve the patient surfaces
  // off `<sub>.neurofax.uz` instead of the default `/c/<slug>`. Globally
  // unique because it routes traffic; nullable because Basic plans don't
  // get one. Wave 2 wires the resolver / DNS playbook.
  customSubdomain            String?   @unique
  // Phase 19 Wave 1 — second brand color for headers / accents on the
  // patient-facing surfaces. White-label feature gate decides whether the
  // UI exposes this; the column is always available so we don't need a
  // second migration when a clinic upgrades.
  brandSecondaryColor        String?
  // Phase 19 Wave 1 — onboarding milestones. `onboardedAt` flips the moment
  // the self-service wizard finishes (Wave 2). `onboardingPlaybook` records
  // which playbook variant the clinic picked (e.g. "dental", "general",
  // "aesthetic") so the seeded demo content + tour highlights match.
  // Free-form string (not enum) because the playbook catalog evolves
  // outside of schema migrations.
  onboardedAt                DateTime?
  onboardingPlaybook         String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  users                   User[]
  doctors                 Doctor[]
  patients                Patient[]
  appointments            Appointment[]
  cabinets                Cabinet[]
  services                Service[]
  payments                Payment[]
  documents               Document[]
  communications          Communication[]
  conversations           Conversation[]
  messages                Message[]
  notificationTemplates   NotificationTemplate[]
  notificationSends       NotificationSend[]
  campaigns               Campaign[]
  calls                   Call[]
  onlineRequests          OnlineRequest[]
  reviews                 Review[]
  exchangeRates           ExchangeRate[]
  providerConnections     ProviderConnection[]
  leads                   Lead[]
  auditLogs               AuditLog[]
  doctorSchedules         DoctorSchedule[]
  doctorTimeOffs          DoctorTimeOff[]
  appointmentServices     AppointmentService[]
  branches                Branch[]
  subscription            Subscription?
  medicalCases            MedicalCase[]
  actions                 Action[]
  emptySlotSnapshots      EmptySlotSnapshot[]
  llmUsages               LLMUsage[]
  patientReviews          PatientReview[]
  patientFamilies         PatientFamily[]
  prescriptions           Prescription[]
  referralCodes           ReferralCode[]
  referralRewards         ReferralReward[]
  medicationReminderSends MedicationReminderSend[]
  patientViews            PatientView[]
  userSessions            UserSession[]
  dataExportJobs          DataExportJob[]
  dataDeletionJobs        DataDeletionJob[]
  savedReports            SavedReport[]
  scheduledReports        ScheduledReport[]
  invoices                Invoice[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Branches (Phase 9a)
//
// A clinic may operate from multiple physical sites. The default per-clinic
// branch is created by migration backfill (slug='hq', isDefault=true) and the
// seed script attaches all generated demo content to it. Application code
// continues to query clinic-wide unless `runWithTenant` carries an explicit
// `branchId` — see `src/lib/tenant-context.ts` and `src/lib/prisma.ts`.
//
// Branch-scoped models keep `branchId` NULLABLE in this migration so prod
// rollouts can backfill at their own pace. Phase 9b tightens to NOT NULL
// after every existing row is reconciled.
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  slug      String
  nameRu    String
  nameUz    String
  address   String?
  phone     String?
  timezone  String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors            Doctor[]
  cabinets           Cabinet[]
  appointments       Appointment[]
  doctorSchedules    DoctorSchedule[]
  doctorTimeOffs     DoctorTimeOff[]
  actions            Action[]
  emptySlotSnapshots EmptySlotSnapshot[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  date      DateTime
  rateUsd   Decimal  @db.Decimal(12, 4)
  source    String?
  createdAt DateTime @default(now())

  @@unique([clinicId, date])
  @@index([clinicId, date])
}

// Encrypted per-tenant provider credentials (tg, sms, payme, etc).
model ProviderConnection {
  id           String       @id @default(cuid())
  clinicId     String
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  kind         ProviderKind
  label        String?
  // Encrypted payload (JSON) — cipher-text only; decryption is app-side.
  secretCipher String
  config       Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([clinicId, kind, label])
  @@index([clinicId, kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Plans + Subscriptions (Phase 9b)
//
// `Plan` is a small catalog of SaaS tiers (basic / pro / enterprise). Feature
// gates live in `features` (Json) so we can extend them without touching the
// schema. `Subscription` ties exactly one plan to one clinic — there is at
// most one active row per clinic (`@unique` on clinicId).
//
// The migration that introduces these tables also seeds the canonical three
// plans and gives every existing clinic a TRIAL on `pro` so prod rollouts
// don't leave anyone behind. Phase 9c builds the admin UI; Phase 9d wires
// feature flags into navigation.
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id         String   @id @default(cuid())
  slug       String   @unique
  nameRu     String
  nameUz     String
  priceMonth Decimal  @db.Decimal(12, 2)
  currency   Currency @default(UZS)
  // {hasTelegramInbox, hasCallCenter, hasAnalyticsPro, maxBranches, maxUsers}
  features   Json
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                  String             @id @default(cuid())
  clinicId            String             @unique
  clinic              Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  // Phase 19 Wave 3 — set when an upgrade is initiated (DRAFT Invoice
  // minted). On the corresponding `INVOICE_PAID` transition we move the
  // value into `planId` and clear this column. Allows the billing UI to
  // show "Upgrade to Pro pending payment" without yet entitling the
  // tenant to the higher tier's feature flags.
  pendingPlanId       String?
  status              SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([currentPeriodEndsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Invoices (Phase 19 Wave 1)
//
// One Invoice row per billing period per clinic. The MVP path:
//   - Wave 2 admin self-service downgrade flow stamps DRAFT/ISSUED rows.
//   - Click/Payme webhooks (Wave 4) flip ISSUED → PAID and populate
//     `paymentRef`. The unpaid sweeper flips ISSUED → OVERDUE after `dueAt`.
//
// `amountTiins` is BigInt because invoice totals span months/years and can
// overflow the Int range used by the per-row Payment model. `number` is the
// human-readable identifier shown to the customer and on the PDF.
// ─────────────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

model Invoice {
  id          String        @id @default(cuid())
  clinicId    String
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  number      String        @unique
  status      InvoiceStatus @default(DRAFT)
  amountTiins BigInt
  currency    Currency      @default(UZS)
  periodStart DateTime
  periodEnd   DateTime
  dueAt       DateTime
  paidAt      DateTime?
  paymentRef  String?
  pdfUrl      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clinicId, createdAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Self-service signup tokens (Phase 19 Wave 2)
//
// One row per `/signup` form submission. The token is a url-safe random ID
// the visitor receives by email; clicking the confirm link consumes the row,
// provisions Clinic + ADMIN + TRIAL Subscription, and applies the chosen
// onboarding playbook.
//
// Intentionally NOT joined back to Clinic — the row outlives the clinic for
// audit purposes (a future GC sweeps consumed/expired rows independently).
// `consumedClinicId` is denormalized so we can correlate without an FK.
// ─────────────────────────────────────────────────────────────────────────────

model ClinicSignupToken {
  id               String    @id @default(cuid())
  email            String
  clinicName       String
  phone            String?
  planSlug         String    @default("basic")
  // null = "start blank" path. Otherwise one of the 5 catalog slugs
  // (general / dental / neurology / pediatric / cosmetology) — kept as a
  // free-form string so the catalog can evolve without a migration.
  playbookSlug     String?
  preferredLocale  String    @default("ru") // "ru" | "uz"
  token            String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedClinicId String?

  @@index([email])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPER_ADMIN impersonation grants (Phase 19 Wave 4)
//
// Today the `admin_clinic_override` cookie is the only mechanism. Wave 4 pairs
// each switch-into-clinic action with a row here so we can:
//   - require a free-text reason (forensic / support audit trail)
//   - time-bound the grant (default 60min lease) and auto-expire
//   - flip into `VIEW_ONLY` mode where the API wrapper rejects writes
//   - emit STARTED / ENDED / EXPIRED audit transitions
//
// No FK back to User or Clinic on purpose: the row must outlive a deleted
// clinic so support / compliance can still see who did what when reviewing
// historical incidents (mirrors `ClinicSignupToken`).
// ─────────────────────────────────────────────────────────────────────────────

enum ImpersonationMode {
  WRITE
  VIEW_ONLY
}

model ImpersonationGrant {
  id           String            @id @default(cuid())
  superAdminId String
  clinicId     String
  reason       String
  mode         ImpersonationMode @default(WRITE)
  startedAt    DateTime          @default(now())
  expiresAt    DateTime
  endedAt      DateTime?
  // "user_exit" | "expired" | "revoked"
  endedReason  String?

  @@index([superAdminId, startedAt])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (NextAuth) + Staff
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  // SUPER_ADMIN has clinicId = null; every other user is bound to a single clinic.
  clinicId           String?
  clinic             Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  email              String
  emailVerified      DateTime?
  passwordHash       String?
  name               String
  photoUrl           String?
  phone              String?
  telegramId         String?
  role               Role      @default(DOCTOR)
  active             Boolean   @default(true)
  // Set true when an admin issues a temp password; cleared on first self-set.
  // Middleware redirects users with this flag to /crm/me/change-password.
  mustChangePassword Boolean   @default(false)
  // The user (SUPER_ADMIN or ADMIN) who created/invited this account.
  // No back-relation needed — surfaced only in audit views.
  invitedById        String?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Phase 17 Wave 2 reservations — added in Wave 1 to avoid a second
  // migration when 2FA + session-rotation lands. Wave 2 will populate
  // `totpSecret` (encrypted) + `recoveryCodesHash` (bcrypt of one-time
  // codes; NEVER plaintext) and start stamping `lastSessionRotatedAt`
  // from session middleware.
  totpSecret           String?
  totpEnabledAt        DateTime?
  recoveryCodesHash    String[]
  lastSessionRotatedAt DateTime?
  // Phase 17 Wave 2 hardening — server-side pinning of an in-flight TOTP
  // enrolment. /enroll writes (pendingTotpSecret, pendingTotpExpiresAt);
  // /verify must match against this row instead of trusting the client to
  // echo back the secret. TTL is short (10 min) and the fields are wiped on
  // successful verify or by the next /enroll call.
  pendingTotpSecret      String?
  pendingTotpExpiresAt   DateTime?

  doctor              Doctor?
  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  patientViews        PatientView[]
  userSessions        UserSession[]
  assignedConvs       Conversation[] @relation("ConversationAssignee")
  calls               Call[]         @relation("CallOperator")
  sentMessages        Message[]      @relation("MessageSender")
  uploadedDocuments   Document[]     @relation("DocumentUploader")
  createdAppointments Appointment[]  @relation("AppointmentCreator")
  createdCampaigns    Campaign[]     @relation("CampaignCreator")
  savedReports        SavedReport[]  @relation("SavedReportCreator")

  // Global uniqueness of email across the whole installation + per-clinic lookup.
  @@unique([email])
  @@index([clinicId, role])
  @@index([clinicId, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Doctor {
  id               String   @id @default(cuid())
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  slug             String
  nameRu           String
  nameUz           String
  specializationRu String
  specializationUz String
  photoUrl         String?
  bioRu            String?  @db.Text
  bioUz            String?  @db.Text
  rating           Decimal? @db.Decimal(3, 2)
  reviewCount      Int      @default(0)
  color            String   @default("#3DD5C0")
  pricePerVisit    Int?
  salaryPercent    Int      @default(40)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Doctor↔Cabinet 1:1 binding. NOT NULL — every doctor must occupy a
  // cabinet (no headless doctors). UNIQUE — one doctor per cabinet, no
  // shared shifts. onDelete: Restrict prevents deleting a cabinet while
  // it's still occupied; admin must reassign first.
  cabinetId String  @unique
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Restrict)

  services           ServiceOnDoctor[]
  schedules          DoctorSchedule[]
  timeOffs           DoctorTimeOff[]
  appointments       Appointment[]
  leads              Lead[]
  primaryCases       MedicalCase[]
  emptySlotSnapshots EmptySlotSnapshot[]
  patientReviews     PatientReview[]
  prescriptions      Prescription[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
  @@index([clinicId, specializationRu])
  @@index([clinicId, branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id             String   @id @default(cuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  code           String
  nameRu         String
  nameUz         String
  category       String?
  durationMin    Int      @default(30)
  priceBase      Int
  // Free-repeat policy: when set, the N-th appointment in the same MedicalCase
  // within `freeRepeatDays` of the case's first appointment is priced at 0.
  // null = no free-repeat policy. Doctor-level overrides may be added later.
  freeRepeatDays Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctors             ServiceOnDoctor[]
  appointmentServices AppointmentService[]
  primaryAppointments Appointment[]        @relation("AppointmentPrimaryService")

  @@unique([clinicId, code])
  @@index([clinicId, isActive])
  @@index([clinicId, category])
}

model ServiceOnDoctor {
  doctorId            String
  serviceId           String
  priceOverride       Int?
  // Per-doctor duration override. null = use Service.durationMin. Lets a
  // senior doctor book longer slots for the same nominal service.
  durationMinOverride Int?
  doctor              Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service             Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
  @@index([serviceId])
}

model Cabinet {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  number    String
  floor     Int?
  nameRu    String?
  nameUz    String?
  equipment String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-reference to the doctor occupying this cabinet, if any. Optional
  // because there's a brief window during onboarding/reassignment when a
  // cabinet exists with no doctor yet attached.
  doctor       Doctor?
  appointments Appointment[]

  @@unique([clinicId, number])
  @@index([clinicId, isActive])
  @@index([clinicId, branchId])
}

model DoctorSchedule {
  id        String    @id @default(cuid())
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  weekday   Int
  startTime String
  endTime   String
  validFrom DateTime?
  validTo   DateTime?
  isActive  Boolean   @default(true)

  @@index([clinicId, doctorId, weekday])
  @@index([clinicId, branchId])
}

model DoctorTimeOff {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([clinicId, doctorId, startAt])
  @@index([clinicId, branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Patients & Appointments
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id                 String               @id @default(cuid())
  clinicId           String
  clinic             Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  fullName           String
  phone              String
  phoneNormalized    String
  birthDate          DateTime?
  gender             Gender?
  passport           String?
  address            String?
  photoUrl           String?
  telegramId         String?
  telegramUsername   String?
  preferredChannel   CommunicationChannel @default(TG)
  preferredLang      Lang                 @default(RU)
  source             LeadSource?
  segment            PatientSegment       @default(NEW)
  tags               String[]
  notes              String?              @db.Text
  ltv                Int                  @default(0)
  visitsCount        Int                  @default(0)
  balance            Int                  @default(0)
  discountPct        Int                  @default(0)
  lastVisitAt        DateTime?
  nextVisitAt        DateTime?
  consentMarketing   Boolean              @default(false)
  // Phase 14 — Revenue Engines.
  // `dormantSince` is stamped by a future engine when the patient crosses an
  // inactivity threshold (no visit/contact within window). `reactivationSentAt`
  // accumulates timestamps for each reactivation campaign send so the engine
  // can enforce once-per-quarter idempotency without a join table.
  dormantSince       DateTime?
  reactivationSentAt DateTime[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Phase 15 Wave 1 — LLM-generated patient summary.
  // `summaryCache` holds the latest auto-summary (last visit highlights,
  // active diagnoses, free-text alerts) shown on the patient card. Wave 2
  // populates it; Wave 1 just reserves the columns. `summaryCacheUpdatedAt`
  // is the cache timestamp used to invalidate on new visit / new note.
  summaryCache          String?   @db.Text
  summaryCacheUpdatedAt DateTime?

  // Phase 17 Wave 1 — Compliance & Trust.
  // `marketingOptOut` is the explicit opt-OUT flag (NOT the same as
  // `consentMarketing` opt-IN). When TRUE, marketing-classified pushes
  // (reactivation, NPS, medication reminders, birthday, referral reward,
  // etc.) are blocked by the consent-gate helper at every send-site.
  // Transactional pushes (appointment confirmation, 24h/5h/2h reminders,
  // appointment.cancelled, pre-visit questionnaire) are NEVER gated.
  // `marketingOptOutSource` records who/what set the flag — the Mini App
  // toggle, an inbound SMS STOP keyword, an admin action, or a future
  // data-deletion request.
  marketingOptOut       Boolean   @default(false)
  marketingOptOutAt     DateTime?
  marketingOptOutSource String?
  // Soft-delete plumbing for Wave 3 DSAR support. `deletedAt` makes the
  // patient invisible to all sends regardless of kind. The deletion path
  // itself (admin approval + actual scrubbing) lands in Wave 3 — Wave 1
  // just reserves the columns so the consent-gate helper can already
  // honour them and we don't need a second migration in Wave 3.
  deletedAt             DateTime?
  deletionRequestedAt   DateTime?
  deletionReason        String?

  appointments              Appointment[]
  payments                  Payment[]
  conversations             Conversation[]
  calls                     Call[]
  notifications             NotificationSend[]
  documents                 Document[]
  communications            Communication[]
  onlineRequests            OnlineRequest[]
  reviews                   Review[]
  leads                     Lead[]
  cases                     MedicalCase[]
  patientReviews            PatientReview[]
  ownedFamilyLinks          PatientFamily[]          @relation("PatientFamilyOwner")
  linkedFamilyLinks         PatientFamily[]          @relation("PatientFamilyLinked")
  prescriptions             Prescription[]
  referralCodes             ReferralCode[]
  referralRewardsAsReferrer ReferralReward[]         @relation("ReferralRewardReferrer")
  referralRewardsAsReferred ReferralReward[]         @relation("ReferralRewardReferred")
  medicationReminderSends   MedicationReminderSend[]
  patientViews              PatientView[]
  dataExportJobs            DataExportJob[]
  dataDeletionJobs          DataDeletionJob[]

  @@unique([clinicId, phoneNormalized])
  @@index([clinicId, fullName])
  @@index([clinicId, segment])
  @@index([clinicId, lastVisitAt])
  @@index([clinicId, createdAt])
  @@index([clinicId, telegramId])
}

model Appointment {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  cabinetId String?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id])

  // Primary service (denormalized for fast filters); additional services live in AppointmentService join.
  serviceId      String?
  primaryService Service? @relation("AppointmentPrimaryService", fields: [serviceId], references: [id])

  date        DateTime
  time        String?
  durationMin Int      @default(30)
  endDate     DateTime

  status       AppointmentStatus @default(BOOKED)
  queueStatus  AppointmentStatus @default(BOOKED)
  queueOrder   Int?
  calledAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  // Optional grouping into a MedicalCase (episode of care). Nullable —
  // appointments may be one-off without a case. onDelete: SetNull keeps
  // the appointment row alive if its case is deleted.
  medicalCaseId String?
  medicalCase   MedicalCase? @relation(fields: [medicalCaseId], references: [id], onDelete: SetNull)

  channel ChannelType @default(WALKIN)
  leadId  String?     @unique
  lead    Lead?       @relation(fields: [leadId], references: [id])

  priceService   Int?
  priceBase      Int?
  discountPct    Int  @default(0)
  discountAmount Int  @default(0)
  priceFinal     Int?

  createdById String?
  createdBy   User?   @relation("AppointmentCreator", fields: [createdById], references: [id])
  comments    String? @db.Text
  notes       String? @db.Text

  // Phase 16 Wave 2 — pre-visit questionnaire (24h before).
  // `preVisitData` is a free-form JSON blob shaped by the `PreVisitData`
  // alias in `src/lib/patient-experience/pre-visit.ts` (complaints, allergies,
  // medications, notes, locale). `preVisitNotifiedAt` is the dedupe stamp set
  // when the worker enqueues the TG push so a re-tick within the 23–25h
  // window doesn't send a second notification. `preVisitSubmittedAt` is set
  // by the Mini App submit endpoint.
  preVisitData        Json?
  preVisitNotifiedAt  DateTime?
  preVisitSubmittedAt DateTime?
  // Phase 16 Wave 2 — post-visit NPS push dedupe stamp. Set by the
  // `post-visit-nps` worker when it enqueues the request push, prevents the
  // hourly tick from spamming the same patient.
  npsRequestedAt      DateTime?

  services       AppointmentService[]
  payments       Payment[]
  documents      Document[]
  conversation   Conversation?
  patientReviews PatientReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, date])
  @@index([clinicId, doctorId, date])
  @@index([clinicId, patientId])
  @@index([clinicId, status])
  @@index([clinicId, queueStatus])
  @@index([clinicId, endDate, cabinetId])
  @@index([clinicId, createdAt])
  @@index([clinicId, branchId])
  @@index([clinicId, medicalCaseId])
}

model AppointmentService {
  clinicId      String
  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  priceSnap     Int
  quantity      Int         @default(1)

  @@id([appointmentId, serviceId])
  @@index([clinicId, appointmentId])
  @@index([serviceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MedicalCase — an episode of care that groups 1..N appointments around a
// single complaint/issue. Multiple parallel cases per patient are normal
// (e.g., back pain + pregnancy = two separate cases). Visit number within a
// case is implicit by ORDER BY appointment.startAt. Appointments may exist
// without a case (one-off visits) — Appointment.medicalCaseId is nullable.
// ─────────────────────────────────────────────────────────────────────────────

model MedicalCase {
  id               String     @id @default(cuid())
  clinicId         String
  clinic           Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId        String
  patient          Patient    @relation(fields: [patientId], references: [id])
  // Primary doctor responsible for the case. Nullable — a case may be
  // multi-doctor or unassigned at creation. SetNull on doctor delete so
  // the case is preserved.
  primaryDoctorId  String?
  primaryDoctor    Doctor?    @relation(fields: [primaryDoctorId], references: [id], onDelete: SetNull)
  title            String
  status           CaseStatus @default(OPEN)
  primaryComplaint String?    @db.Text
  diagnosisText    String?    @db.Text
  // Reserved for ICD-10 (or local ICD-equivalent) — schema-only, no UI yet.
  diagnosisCode    String?
  notes            String?    @db.Text
  // Phase 15 Wave 1 — voice-transcribed SOAP draft.
  // Populated by the Whisper→LLM worker (Wave 3) from doctor TG voice notes;
  // doctor edits the draft on the case page. Wave 1 just reserves the column.
  soapDraft        String?    @db.Text
  openedAt         DateTime   @default(now())
  closedAt         DateTime?
  closedReason     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  appointments      Appointment[]
  notificationSends NotificationSend[]
  prescriptions     Prescription[]

  @@index([clinicId, patientId, status])
  @@index([clinicId, status, openedAt])
  @@index([clinicId, primaryDoctorId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])

  currency       Currency      @default(UZS)
  amount         Int // minor units of `currency`
  amountUsdSnap  Int? // snapshot in USD cents at payment time
  fxRate         Decimal?      @db.Decimal(12, 4)
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  receiptNumber  String?
  receiptUrl     String?
  refundedAmount Int           @default(0)
  paidAt         DateTime?
  externalRef    String?
  /// Client-supplied idempotency key. Null = retries can dedupe themselves
  /// however they want; non-null = unique per clinic so a network retry with
  /// the same key returns the original row instead of creating a duplicate.
  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, idempotencyKey], map: "Payment_clinicId_idempotencyKey_key")
  @@index([clinicId, status])
  @@index([clinicId, paidAt])
  @@index([clinicId, appointmentId])
  @@index([clinicId, patientId])
  @@index([clinicId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Documents
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  type          DocumentType
  title         String
  fileUrl       String
  mimeType      String?
  sizeBytes     Int?
  uploadedById  String?
  uploadedBy    User?        @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime     @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Communications — lightweight audit trail of all outbound/inbound touches.
// (Chat threads live in Conversation/Message.)
// ─────────────────────────────────────────────────────────────────────────────

model Communication {
  id        String                 @id @default(cuid())
  clinicId  String
  clinic    Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId String?
  patient   Patient?               @relation(fields: [patientId], references: [id])
  channel   CommunicationChannel
  direction CommunicationDirection
  subject   String?
  body      String?                @db.Text
  meta      Json?
  createdAt DateTime               @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, channel, createdAt])
}

model Conversation {
  id               String               @id @default(cuid())
  clinicId         String
  clinic           Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  channel          CommunicationChannel
  mode             ConversationMode     @default(bot)
  patientId        String?
  patient          Patient?             @relation(fields: [patientId], references: [id])
  appointmentId    String?              @unique
  appointment      Appointment?         @relation(fields: [appointmentId], references: [id])
  externalId       String?
  contactFirstName String?
  contactLastName  String?
  contactUsername  String?
  status           ConversationStatus   @default(OPEN)
