// MedBook / NeuroFax — initial multi-tenant schema (Phase 1)
// All operational entities carry clinicId + FK to Clinic.
// Unique keys within a clinic are composite (clinicId, ...).
// Money is stored as Int in minor units (tiyin for UZS, cents for USD).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  NURSE
  CALL_OPERATOR
}

enum Currency {
  UZS
  USD
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  PAYME
  CLICK
  UZUM
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum AppointmentStatus {
  BOOKED
  WAITING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  CANCELLED
  NO_SHOW
}

enum PatientSegment {
  NEW
  ACTIVE
  DORMANT
  VIP
  CHURN
}

enum ChannelType {
  WALKIN
  PHONE
  TELEGRAM
  WEBSITE
  KIOSK
}

enum CommunicationChannel {
  SMS
  TG
  CALL
  EMAIL
  VISIT
}

enum CommunicationDirection {
  IN
  OUT
}

enum ConversationMode {
  bot
  takeover
}

enum TemplateCategory {
  REMINDER
  MARKETING
  TRANSACTIONAL
}

enum Gender {
  MALE
  FEMALE
}

enum Lang {
  RU
  UZ
}

enum ConversationStatus {
  OPEN
  SNOOZED
  CLOSED
}

enum MessageDirection {
  IN
  OUT
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

enum NotificationTrigger {
  MANUAL
  APPOINTMENT_CREATED
  APPOINTMENT_BEFORE
  APPOINTMENT_MISSED
  APPOINTMENT_COMPLETED
  PATIENT_BIRTHDAY
  PATIENT_INACTIVE_DAYS
  CRON
}

enum CallDirection {
  IN
  OUT
  MISSED
}

enum DocumentType {
  REFERRAL
  PRESCRIPTION
  RESULT
  CONSENT
  CONTRACT
  RECEIPT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CANCELLED
}

enum LeadSource {
  WEBSITE
  TELEGRAM
  INSTAGRAM
  CALL
  WALKIN
  REFERRAL
  ADS
  OTHER
}

enum ProviderKind {
  TELEGRAM
  SMS
  PAYME
  CLICK
  UZUM
  OPENAI
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

model Clinic {
  id                String    @id @default(cuid())
  slug              String    @unique
  nameRu            String
  nameUz            String
  addressRu         String?
  addressUz         String?
  phone             String?
  email             String?
  logoUrl           String?
  brandColor        String    @default("#3DD5C0")
  timezone          String    @default("Asia/Tashkent")
  currency          Currency  @default(UZS)
  secondaryCurrency Currency?
  exchangeRateToUsd Decimal?  @db.Decimal(12, 4)
  workdayStart      String    @default("09:00")
  workdayEnd        String    @default("19:00")
  slotMin           Int       @default(30)
  tgBotUsername     String?
  tgBotToken        String?
  tgWebhookSecret   String?
  smsSenderName     String?
  kioskPin          String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users                 User[]
  doctors               Doctor[]
  patients              Patient[]
  appointments          Appointment[]
  cabinets              Cabinet[]
  services              Service[]
  payments              Payment[]
  documents             Document[]
  communications        Communication[]
  conversations         Conversation[]
  messages              Message[]
  notificationTemplates NotificationTemplate[]
  notificationSends     NotificationSend[]
  campaigns             Campaign[]
  calls                 Call[]
  onlineRequests        OnlineRequest[]
  reviews               Review[]
  exchangeRates         ExchangeRate[]
  providerConnections   ProviderConnection[]
  leads                 Lead[]
  auditLogs             AuditLog[]
  doctorSchedules       DoctorSchedule[]
  doctorTimeOffs        DoctorTimeOff[]
  appointmentServices   AppointmentService[]
  branches              Branch[]
  subscription          Subscription?
}

// ─────────────────────────────────────────────────────────────────────────────
// Branches (Phase 9a)
//
// A clinic may operate from multiple physical sites. The default per-clinic
// branch is created by migration backfill (slug='hq', isDefault=true) and the
// seed script attaches all generated demo content to it. Application code
// continues to query clinic-wide unless `runWithTenant` carries an explicit
// `branchId` — see `src/lib/tenant-context.ts` and `src/lib/prisma.ts`.
//
// Branch-scoped models keep `branchId` NULLABLE in this migration so prod
// rollouts can backfill at their own pace. Phase 9b tightens to NOT NULL
// after every existing row is reconciled.
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  slug      String
  nameRu    String
  nameUz    String
  address   String?
  phone     String?
  timezone  String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors         Doctor[]
  cabinets        Cabinet[]
  appointments    Appointment[]
  doctorSchedules DoctorSchedule[]
  doctorTimeOffs  DoctorTimeOff[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  date      DateTime
  rateUsd   Decimal  @db.Decimal(12, 4)
  source    String?
  createdAt DateTime @default(now())

  @@unique([clinicId, date])
  @@index([clinicId, date])
}

// Encrypted per-tenant provider credentials (tg, sms, payme, etc).
model ProviderConnection {
  id           String       @id @default(cuid())
  clinicId     String
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  kind         ProviderKind
  label        String?
  // Encrypted payload (JSON) — cipher-text only; decryption is app-side.
  secretCipher String
  config       Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([clinicId, kind, label])
  @@index([clinicId, kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Plans + Subscriptions (Phase 9b)
//
// `Plan` is a small catalog of SaaS tiers (basic / pro / enterprise). Feature
// gates live in `features` (Json) so we can extend them without touching the
// schema. `Subscription` ties exactly one plan to one clinic — there is at
// most one active row per clinic (`@unique` on clinicId).
//
// The migration that introduces these tables also seeds the canonical three
// plans and gives every existing clinic a TRIAL on `pro` so prod rollouts
// don't leave anyone behind. Phase 9c builds the admin UI; Phase 9d wires
// feature flags into navigation.
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id         String   @id @default(cuid())
  slug       String   @unique
  nameRu     String
  nameUz     String
  priceMonth Decimal  @db.Decimal(12, 2)
  currency   Currency @default(UZS)
  // {hasTelegramInbox, hasCallCenter, hasAnalyticsPro, maxBranches, maxUsers}
  features   Json
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                  String             @id @default(cuid())
  clinicId            String             @unique
  clinic              Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  status              SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([currentPeriodEndsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (NextAuth) + Staff
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  // SUPER_ADMIN has clinicId = null; every other user is bound to a single clinic.
  clinicId      String?
  clinic        Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  email         String
  emailVerified DateTime?
  passwordHash  String?
  name          String
  photoUrl      String?
  phone         String?
  telegramId    String?
  role          Role      @default(DOCTOR)
  active        Boolean   @default(true)
  // Set true when an admin issues a temp password; cleared on first self-set.
  // Middleware redirects users with this flag to /crm/me/change-password.
  mustChangePassword Boolean @default(false)
  // The user (SUPER_ADMIN or ADMIN) who created/invited this account.
  // No back-relation needed — surfaced only in audit views.
  invitedById   String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  doctor              Doctor?
  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  assignedConvs       Conversation[] @relation("ConversationAssignee")
  calls               Call[]         @relation("CallOperator")
  sentMessages        Message[]      @relation("MessageSender")
  uploadedDocuments   Document[]     @relation("DocumentUploader")
  createdAppointments Appointment[]  @relation("AppointmentCreator")
  createdCampaigns    Campaign[]     @relation("CampaignCreator")

  // Global uniqueness of email across the whole installation + per-clinic lookup.
  @@unique([email])
  @@index([clinicId, role])
  @@index([clinicId, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Doctor {
  id               String   @id @default(cuid())
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id])
  slug             String
  nameRu           String
  nameUz           String
  specializationRu String
  specializationUz String
  photoUrl         String?
  bioRu            String?  @db.Text
  bioUz            String?  @db.Text
  rating           Decimal? @db.Decimal(3, 2)
  reviewCount      Int      @default(0)
  color            String   @default("#3DD5C0")
  pricePerVisit    Int?
  salaryPercent    Int      @default(40)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Doctor↔Cabinet 1:1 binding. NOT NULL — every doctor must occupy a
  // cabinet (no headless doctors). UNIQUE — one doctor per cabinet, no
  // shared shifts. onDelete: Restrict prevents deleting a cabinet while
  // it's still occupied; admin must reassign first.
  cabinetId String  @unique
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Restrict)

  services     ServiceOnDoctor[]
  schedules    DoctorSchedule[]
  timeOffs     DoctorTimeOff[]
  appointments Appointment[]
  leads        Lead[]

  @@unique([clinicId, slug])
  @@index([clinicId, isActive])
  @@index([clinicId, specializationRu])
  @@index([clinicId, branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  code        String
  nameRu      String
  nameUz      String
  category    String?
  durationMin Int      @default(30)
  priceBase   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors             ServiceOnDoctor[]
  appointmentServices AppointmentService[]
  primaryAppointments Appointment[]        @relation("AppointmentPrimaryService")

  @@unique([clinicId, code])
  @@index([clinicId, isActive])
  @@index([clinicId, category])
}

model ServiceOnDoctor {
  doctorId            String
  serviceId           String
  priceOverride       Int?
  // Per-doctor duration override. null = use Service.durationMin. Lets a
  // senior doctor book longer slots for the same nominal service.
  durationMinOverride Int?
  doctor              Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service             Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
  @@index([serviceId])
}

model Cabinet {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  number    String
  floor     Int?
  nameRu    String?
  nameUz    String?
  equipment String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-reference to the doctor occupying this cabinet, if any. Optional
  // because there's a brief window during onboarding/reassignment when a
  // cabinet exists with no doctor yet attached.
  doctor       Doctor?
  appointments Appointment[]

  @@unique([clinicId, number])
  @@index([clinicId, isActive])
  @@index([clinicId, branchId])
}

model DoctorSchedule {
  id        String    @id @default(cuid())
  clinicId  String
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  weekday   Int
  startTime String
  endTime   String
  validFrom DateTime?
  validTo   DateTime?
  isActive  Boolean   @default(true)

  @@index([clinicId, doctorId, weekday])
  @@index([clinicId, branchId])
}

model DoctorTimeOff {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([clinicId, doctorId, startAt])
  @@index([clinicId, branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Patients & Appointments
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id               String               @id @default(cuid())
  clinicId         String
  clinic           Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  fullName         String
  phone            String
  phoneNormalized  String
  birthDate        DateTime?
  gender           Gender?
  passport         String?
  address          String?
  photoUrl         String?
  telegramId       String?
  telegramUsername String?
  preferredChannel CommunicationChannel @default(TG)
  preferredLang    Lang                 @default(RU)
  source           LeadSource?
  segment          PatientSegment       @default(NEW)
  tags             String[]
  notes            String?              @db.Text
  ltv              Int                  @default(0)
  visitsCount      Int                  @default(0)
  balance          Int                  @default(0)
  discountPct      Int                  @default(0)
  lastVisitAt      DateTime?
  nextVisitAt      DateTime?
  consentMarketing Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  appointments   Appointment[]
  payments       Payment[]
  conversations  Conversation[]
  calls          Call[]
  notifications  NotificationSend[]
  documents      Document[]
  communications Communication[]
  onlineRequests OnlineRequest[]
  reviews        Review[]
  leads          Lead[]

  @@unique([clinicId, phoneNormalized])
  @@index([clinicId, fullName])
  @@index([clinicId, segment])
  @@index([clinicId, lastVisitAt])
  @@index([clinicId, createdAt])
  @@index([clinicId, telegramId])
}

model Appointment {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  cabinetId String?
  cabinet   Cabinet? @relation(fields: [cabinetId], references: [id])

  // Primary service (denormalized for fast filters); additional services live in AppointmentService join.
  serviceId      String?
  primaryService Service? @relation("AppointmentPrimaryService", fields: [serviceId], references: [id])

  date        DateTime
  time        String?
  durationMin Int      @default(30)
  endDate     DateTime

  status       AppointmentStatus @default(BOOKED)
  queueStatus  AppointmentStatus @default(BOOKED)
  queueOrder   Int?
  calledAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  channel ChannelType @default(WALKIN)
  leadId  String?     @unique
  lead    Lead?       @relation(fields: [leadId], references: [id])

  priceService   Int?
  priceBase      Int?
  discountPct    Int  @default(0)
  discountAmount Int  @default(0)
  priceFinal     Int?

  createdById String?
  createdBy   User?   @relation("AppointmentCreator", fields: [createdById], references: [id])
  comments    String? @db.Text
  notes       String? @db.Text

  services     AppointmentService[]
  payments     Payment[]
  documents    Document[]
  conversation Conversation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, date])
  @@index([clinicId, doctorId, date])
  @@index([clinicId, patientId])
  @@index([clinicId, status])
  @@index([clinicId, queueStatus])
  @@index([clinicId, endDate, cabinetId])
  @@index([clinicId, createdAt])
  @@index([clinicId, branchId])
}

model AppointmentService {
  clinicId      String
  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  priceSnap     Int
  quantity      Int         @default(1)

  @@id([appointmentId, serviceId])
  @@index([clinicId, appointmentId])
  @@index([serviceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])

  currency       Currency      @default(UZS)
  amount         Int // minor units of `currency`
  amountUsdSnap  Int? // snapshot in USD cents at payment time
  fxRate         Decimal?      @db.Decimal(12, 4)
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  receiptNumber  String?
  receiptUrl     String?
  refundedAmount Int           @default(0)
  paidAt         DateTime?
  externalRef    String?
  /// Client-supplied idempotency key. Null = retries can dedupe themselves
  /// however they want; non-null = unique per clinic so a network retry with
  /// the same key returns the original row instead of creating a duplicate.
  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, idempotencyKey], map: "Payment_clinicId_idempotencyKey_key")
  @@index([clinicId, status])
  @@index([clinicId, paidAt])
  @@index([clinicId, appointmentId])
  @@index([clinicId, patientId])
  @@index([clinicId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Documents
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  type          DocumentType
  title         String
  fileUrl       String
  mimeType      String?
  sizeBytes     Int?
  uploadedById  String?
  uploadedBy    User?        @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime     @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Communications — lightweight audit trail of all outbound/inbound touches.
// (Chat threads live in Conversation/Message.)
// ─────────────────────────────────────────────────────────────────────────────

model Communication {
  id        String                 @id @default(cuid())
  clinicId  String
  clinic    Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId String?
  patient   Patient?               @relation(fields: [patientId], references: [id])
  channel   CommunicationChannel
  direction CommunicationDirection
  subject   String?
  body      String?                @db.Text
  meta      Json?
  createdAt DateTime               @default(now())

  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, channel, createdAt])
}

model Conversation {
  id              String               @id @default(cuid())
  clinicId        String
  clinic          Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  channel         CommunicationChannel
  mode            ConversationMode     @default(bot)
  patientId       String?
  patient         Patient?             @relation(fields: [patientId], references: [id])
  appointmentId   String?              @unique
  appointment     Appointment?         @relation(fields: [appointmentId], references: [id])
  externalId      String?
  contactFirstName String?
  contactLastName  String?
  contactUsername  String?
  status          ConversationStatus   @default(OPEN)
  assignedToId    String?
  assignedTo      User?                @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  tags            String[]
  lastMessageAt   DateTime?
  lastMessageText String?
  unreadCount     Int                  @default(0)
  snoozedUntil    DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  messages Message[]

  @@unique([clinicId, externalId])
  @@index([clinicId, status, lastMessageAt])
  @@index([clinicId, assignedToId, status])
  @@index([clinicId, patientId])
}

model Message {
  id             String           @id @default(cuid())
  clinicId       String
  clinic         Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  body           String?          @db.Text
  attachments    Json?
  buttons        Json?
  senderId       String?
  sender         User?            @relation("MessageSender", fields: [senderId], references: [id])
  status         MessageStatus    @default(SENT)
  externalId     String?
  replyToId      String?
  createdAt      DateTime         @default(now())

  @@unique([clinicId, externalId])
  @@index([clinicId, conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications & Campaigns
// ─────────────────────────────────────────────────────────────────────────────

model NotificationTemplate {
  id            String               @id @default(cuid())
  clinicId      String
  clinic        Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  key           String
  nameRu        String
  nameUz        String
  channel       CommunicationChannel
  category      TemplateCategory
  bodyRu        String               @db.Text
  bodyUz        String               @db.Text
  buttons       Json?
  variables     String[]
  trigger       NotificationTrigger  @default(MANUAL)
  triggerConfig Json?
  isActive      Boolean              @default(true)
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  sends     NotificationSend[]
  campaigns Campaign[]

  @@unique([clinicId, key])
  @@index([clinicId, category])
  @@index([clinicId, isActive])
}

model NotificationSend {
  id            String                @id @default(cuid())
  clinicId      String
  clinic        Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  templateId    String?
  template      NotificationTemplate? @relation(fields: [templateId], references: [id])
  campaignId    String?
  campaign      Campaign?             @relation(fields: [campaignId], references: [id])
  patientId     String
  patient       Patient               @relation(fields: [patientId], references: [id])
  appointmentId String?
  channel       CommunicationChannel
  recipient     String
  body          String                @db.Text
  status        NotificationStatus    @default(QUEUED)
  scheduledFor  DateTime
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failedReason  String?
  externalId    String?
  retryCount    Int                   @default(0)
  createdAt     DateTime              @default(now())

  @@index([clinicId, status, scheduledFor])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, campaignId])
}

model Campaign {
  id           String                @id @default(cuid())
  clinicId     String
  clinic       Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name         String
  templateId   String?
  template     NotificationTemplate? @relation(fields: [templateId], references: [id])
  segment      Json? // filter definition
  channel      CommunicationChannel
  status       String                @default("DRAFT")
  scheduledFor DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  totalCount   Int                   @default(0)
  sentCount    Int                   @default(0)
  failedCount  Int                   @default(0)
  createdById  String?
  createdBy    User?                 @relation("CampaignCreator", fields: [createdById], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  sends NotificationSend[]

  @@index([clinicId, status, scheduledFor])
  @@index([clinicId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Call center / Online requests / Reviews
// ─────────────────────────────────────────────────────────────────────────────

model Call {
  id            String        @id @default(cuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  direction     CallDirection
  fromNumber    String
  toNumber      String
  patientId     String?
  patient       Patient?      @relation(fields: [patientId], references: [id])
  operatorId    String?
  operator      User?         @relation("CallOperator", fields: [operatorId], references: [id])
  appointmentId String?
  durationSec   Int?
  recordingUrl  String?
  summary       String?       @db.Text
  tags          String[]
  sipCallId     String?
  createdAt     DateTime      @default(now())
  endedAt       DateTime?

  @@unique([clinicId, sipCallId])
  @@index([clinicId, patientId, createdAt])
  @@index([clinicId, operatorId, createdAt])
  @@index([clinicId, direction, createdAt])
}

model OnlineRequest {
  id          String      @id @default(cuid())
  clinicId    String
  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  service     String?
  doctorId    String?
  preferredAt DateTime?
  channel     ChannelType
  status      LeadStatus  @default(NEW)
  source      LeadSource  @default(WEBSITE)
  utm         Json?
  comment     String?     @db.Text
  patientId   String?
  patient     Patient?    @relation(fields: [patientId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
}

// Legacy-compatible lead (form submissions converted into Appointments)
model Lead {
  id        String     @id @default(cuid())
  clinicId  String
  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  service   String?
  date      DateTime?
  doctorId  String?
  doctor    Doctor?    @relation(fields: [doctorId], references: [id])
  patientId String?
  patient   Patient?   @relation(fields: [patientId], references: [id])
  status    LeadStatus @default(NEW)
  source    LeadSource @default(WEBSITE)
  utm       Json?
  comment   String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  appointment Appointment?

  @@index([clinicId, status, createdAt])
  @@index([clinicId, phone])
}

model Review {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  authorName  String
  rating      Int
  text        String   @db.Text
  source      String   @default("yandex")
  sourceUrl   String?
  publishedAt DateTime @default(now())
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId, visible, publishedAt])
  @@index([clinicId, rating])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit log
// NOTE: AuditLog has clinicId for reporting/filtering, but is intentionally
// EXCLUDED from the Prisma multi-tenant middleware allowlist so system actions
// can always be recorded even in cross-tenant or SUPER_ADMIN contexts.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String?
  clinic     Clinic?  @relation(fields: [clinicId], references: [id])
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  actorRole  String?
  actorLabel String?
  action     String
  entityType String
  entityId   String?
  meta       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
